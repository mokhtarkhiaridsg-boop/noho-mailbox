// iter-129 + iter-192 — Member's saved forwarding-address book.
// iter-192 promoted from a minimal {label, address} model to a full
// address book: per-row default flag (exactly one default per user
// enforced in server action via demote-siblings), optional recipient
// name override, category enum for visual grouping, free-text notes,
// lastUsedAt stamped by iter-170 batch sweep.
model ForwardingAddress {
  id            String   @id @default(cuid())
  userId        String
  label         String                         // member-friendly nickname e.g. "Snowbird condo"
  address       String                         // multi-line street address
  recipientName String?                        // optional name override on the package
  category      String?                        // "home" | "work" | "snowbird" | "family" | "storage" | "other"
  notes         String?                        // ≤300 chars
  isDefault     Boolean  @default(false)
  lastUsedAt    DateTime?                      // bumped by iter-170 when used in a batch
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
  @@index([userId, lastUsedAt])
}

model ContactSubmission {

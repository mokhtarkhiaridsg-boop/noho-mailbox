generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  phone            String?
  passwordHash     String   // For OAuth-only users, this is set to an unguessable random hash
  oauthProvider    String?  // "google" | "apple" | null
  image            String?
  role             String   @default("USER") // "USER" | "ADMIN"
  plan             String?  // "Basic" | "Business" | "Premium"
  planTerm         String?  // "3" | "6" | "14"
  suiteNumber      String?  @unique
  status           String   @default("Active") // "Active" | "Expired"
  squareCustomerId String?  @unique // Linked Square customer ID

  // iPostal1-parity fields
  securityDepositCents      Int       @default(5000)
  securityDepositTotalCents Int       @default(5000)
  kycStatus                 String    @default("Pending") // "Pending" | "Submitted" | "Approved" | "Rejected"
  kycForm1583Url            String?
  kycIdImageUrl             String?
  kycReviewedAt             DateTime?
  kycReviewedBy             String?
  kycNotes                  String?
  mailboxStatus             String    @default("Pending") // "Pending" | "Assigned" | "Active" | "Suspended"
  mailboxAssignedAt         DateTime?
  totpSecret                String?
  totpEnabled               Boolean   @default(false)
  walletBalanceCents        Int       @default(0)
  defaultCardId             String?
  notifPrefs                String?
  organizationId            String?
  planDueDate               String?   // e.g. "2025-06-15" — admin-set due date for plan renewal
  tosAcceptedAt             DateTime?
  kycIdImage2Url            String?   // Second ID for CMRA compliance
  idPrimaryExpDate          String?   // e.g. "2027-03-15"
  idSecondaryExpDate        String?   // e.g. "2028-01-01"
  idPrimaryType             String?   // "DL" | "Passport" | "State ID" | "Military" | etc.
  idSecondaryType           String?
  idPrimaryNumber           String?   // license #, passport #, policy #, lease #, etc. — free-form
  idSecondaryNumber         String?
  idPrimaryIssuer           String?   // optional: state / country / issuing authority
  idSecondaryIssuer         String?
  planExpiresAt             DateTime?
  planAutoRenew             Boolean   @default(false)

  // Box ownership type — required for CMRA compliance.
  // A company cannot exist as an individual; if Business, an Owner must be on file.
  boxType                   String?   // "Personal" | "Business"
  businessName              String?   // Legal business name (only when boxType=Business)
  businessOwnerName         String?   // Individual personally responsible
  businessOwnerRelation     String?   // "Owner" | "Officer" | "Member" | "Director" | etc.
  businessOwnerPhone        String?

  cardLast4         String?   // Last 4 digits of card on file
  cardBrand         String?   // "Visa" | "Mastercard" | "Amex" | "Discover"
  cardExpiry        String?   // "MM/YY"
  cardholderName    String?
  cardDiscountPct   Int       @default(0)  // % discount applied to this customer (0-100)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mailItems           MailItem[]
  notaryBookings      NotaryBooking[]
  deliveryOrders      DeliveryOrder[]
  shopOrders          ShopOrder[]
  forwardingAddresses ForwardingAddress[]
  payments            Payment[]
  cards               Card[]
  invoices            Invoice[]
  walletTransactions  WalletTransaction[]
  vaultItems          DocumentVaultItem[]
  mailRequests        MailRequest[]
  keyRequests         KeyRequest[]
  shippoLabels        ShippoLabel[]
  labelUploads        LabelUpload[]
  labelOrders         LabelOrder[]
  mailboxRenewals     MailboxRenewal[]
  customerNotes       CustomerNote[]
  notifications       Notification[]
  pickupToken             String?   @unique // short token for QR express pickup; unique because admin scans by token to find user
  referrals               Referral[] @relation("ReferrerReferrals")
  recurringDeliveries     RecurringDelivery[]
  cancellationRequests    CancellationRequest[]
  junkSenders             JunkSender[]
  vacationHold            VacationHold?
  guestPickups            GuestPickupAuth[]
  scheduledForwardings    ScheduledForwarding[]
  sharedAccessGranted     SharedMailboxAccess[] @relation("PrimaryUser")
  sharedAccessReceived    SharedMailboxAccess[] @relation("SharedUser")
  posSales                POSSale[]
}

model SharedMailboxAccess {
  id            String   @id @default(cuid())
  primaryUserId String   // mailbox owner
  sharedUserId  String   // person who gets read access
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  primaryUser User @relation("PrimaryUser", fields: [primaryUserId], references: [id], onDelete: Cascade)
  sharedUser  User @relation("SharedUser", fields: [sharedUserId], references: [id], onDelete: Cascade)
}

model GuestPickupAuth {
  id          String    @id @default(cuid())
  userId      String
  guestName   String
  guestPhone  String?
  guestEmail  String?
  expiresAt   DateTime?
  usedAt      DateTime?
  active      Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduledForwarding {
  id              String   @id @default(cuid())
  userId          String
  addressId       String?  // ForwardingAddress.id (null = default address)
  frequency       String   @default("weekly") // "weekly" | "biweekly" | "monthly"
  nextRunDate     String   // "2025-07-01"
  active          Boolean  @default(true)
  lastRunDate     String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MailItem {
  id           String   @id @default(cuid())
  userId       String
  from         String
  type         String   // "Letter" | "Package"
  status       String   @default("Received") // "Received" | "Scanned" | "Awaiting Pickup" | "Forwarded" | "Picked Up" | "Held" | "X Requested"
  scanned      Boolean  @default(false)
  scanImageUrl String?
  label        String?
  date         String

  // iPostal1 mail intake fields
  weightOz         Float?
  dimensions       String?
  exteriorImageUrl String?
  assignedAt       DateTime?
  holdUntil        DateTime?
  feeChargedCents  Int?
  recipientName    String?   // Name on the label / who it's addressed to
  recipientPhone   String?   // Optional phone for recipient
  priority         Boolean   @default(false) // member-flagged as priority
  junkBlocked      Boolean   @default(false) // auto-blocked by junk sender rule
  trackingNumber   String?   // package tracking number
  carrier          String?   // "UPS" | "USPS" | "FedEx" | "DHL" | "Amazon"

  createdAt    DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests MailRequest[]

  // Hot-path indexes — dashboard reads /admin reads scan by these constantly.
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status])
  @@index([date])
}

model JunkSender {
  id        String   @id @default(cuid())
  userId    String
  sender    String   // sender name/address pattern to block
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VacationHold {
  id        String    @id @default(cuid())
  userId    String    @unique
  startDate String    // "2025-07-01"
  endDate   String    // "2025-07-14"
  digest    Boolean   @default(true) // send daily digest email
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringDelivery {
  id          String   @id @default(cuid())
  userId      String
  frequency   String   @default("weekly") // "weekly" | "biweekly" | "monthly"
  destination String
  tier        String   @default("standard") // "standard" | "express"
  notes       String?
  nextRunDate String   // "2025-07-01"
  lastRunDate String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotaryBooking {
  id        String   @id @default(cuid())
  userId    String
  date      String
  time      String
  type      String
  status    String   @default("Pending")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryOrder {
  id           String   @id @default(cuid())
  userId       String?
  customerName String
  phone        String
  email        String
  pickupAddr   String   @default("NOHO Mailbox, North Hollywood, CA")
  destination  String
  zip          String
  zone         String
  price        Float
  itemType     String
  instructions String?
  courier      String?
  status       String   @default("Pending") // "Pending" | "Picked Up" | "In Transit" | "Delivered"
  date         String

  // iPostal1 delivery extensions
  tier            String    @default("Standard") // "Standard" | "Rush" | "WhiteGlove"
  etaWindow       String?
  pickedUpAt      DateTime?
  inTransitAt     DateTime?
  deliveredAt     DateTime?
  podSignatureUrl String?
  podPhotoUrl     String?
  recipientName   String?
  recipientPhone  String?
  dimensions      String?
  weightOz        Float?
  invoiceId       String?

  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ShopOrder {
  id            String   @id @default(cuid())
  userId        String
  items         String
  total         Float
  status        String   @default("Pending")
  squareOrderId String?  @unique
  date          String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForwardingAddress {
  id      String @id @default(cuid())
  userId  String
  label   String
  address String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  service   String?
  message   String
  createdAt DateTime @default(now())
}

model Payment {
  id               String   @id @default(cuid())
  squarePaymentId  String   @unique
  userId           String?
  amount           Int
  currency         String   @default("USD")
  status           String
  sourceType       String?
  receiptUrl       String?
  note             String?
  squareCreatedAt  String
  syncedAt         DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  // Admin payments view sorts by syncedAt + filters by status. Refund-cap
  // computation reads sum(amount) by userId + status.
  @@index([userId, status])
  @@index([status, syncedAt])
}

model CatalogItem {
  id              String   @id @default(cuid())
  squareCatalogId String   @unique
  name            String
  description     String?
  price           Int
  currency        String   @default("USD")
  category        String?
  inStock         Boolean  @default(true)
  imageUrl        String?
  syncedAt        DateTime @default(now())
}

model SquareSyncLog {
  id          String    @id @default(cuid())
  syncType    String
  status      String
  itemsSynced Int       @default(0)
  errors      String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

// ============================================================
// iPostal1-parity new models
// ============================================================

model Card {
  id           String   @id @default(cuid())
  userId       String
  squareCardId String   @unique
  brand        String
  last4        String
  expMonth     Int
  expYear      Int
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String    @id @default(cuid())
  userId      String
  number      String    @unique
  kind        String    // "Membership" | "Forward" | "Scan" | "Delivery" | "KeyReplacement" | "Shop" | "Notary"
  description String
  amountCents Int
  taxCents    Int       @default(0)
  totalCents  Int
  status      String    @default("Draft") // "Draft" | "Sent" | "Paid" | "Void"
  paymentId   String?
  pdfUrl      String?
  sentAt      DateTime?
  paidAt      DateTime?
  dueAt       DateTime?
  createdAt   DateTime  @default(now())

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment             Payment?            @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  walletTransactions  WalletTransaction[]
}

model WalletTransaction {
  id                String   @id @default(cuid())
  userId            String
  kind              String   // "TopUp" | "Charge" | "DepositCharge" | "DepositRefund" | "Refund"
  amountCents       Int      // signed
  description       String
  balanceAfterCents Int
  invoiceId         String?
  createdAt         DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // Late-fee idempotency check (`billing.ts:runLateFeesBatch`) hits this
  // index every batch. Dashboard wallet history sorts by createdAt.
  @@index([userId, createdAt])
  @@index([userId, kind, createdAt])
}

model MessageThread {
  id                String   @id @default(cuid())
  subject           String
  participantIds    String   // JSON array
  folder            String   @default("Inbox") // "Inbox" | "Sent" | "Archive" | "Trash"
  labels            String?  // JSON array
  lastMessageAt     DateTime @default(now())
  unreadForUserIds  String?  // JSON array
  createdAt         DateTime @default(now())

  messages Message[]
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  body       String
  readByIds  String?  // JSON array
  createdAt  DateTime @default(now())

  thread      MessageThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  filename  String
  mimeType  String
  sizeBytes Int
  blobUrl   String
  kind      String   // "Image" | "Video" | "Document" | "Other"

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model DocumentVaultItem {
  id                String   @id @default(cuid())
  userId            String
  kind              String   // "Scan" | "Invoice" | "Receipt" | "POD" | "Form1583" | "Other"
  title             String
  blobUrl           String
  mimeType          String
  sizeBytes         Int
  sourceMailItemId  String?
  sourceInvoiceId   String?
  sourceDeliveryId  String?
  tags              String?  // JSON array
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MailRequest {
  id          String    @id @default(cuid())
  mailItemId  String
  userId      String
  kind        String    // "Scan" | "Forward" | "Discard" | "Pickup" | "Consolidate" | "Hold" | "Shred" | "Deposit"
  status      String    @default("Pending") // "Pending" | "In Progress" | "Completed" | "Cancelled"
  notes       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  completedBy String?

  mailItem MailItem @relation(fields: [mailItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KeyRequest {
  id          String    @id @default(cuid())
  userId      String
  reason      String
  status      String    @default("Pending") // "Pending" | "Approved" | "Issued" | "Cancelled"
  feeCents    Int       @default(2500)
  invoiceId   String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String
  action     String
  entityType String
  entityId   String?
  metadata   String?  // JSON
  ipAddress  String?
  createdAt  DateTime @default(now())

  // AuditLog grows fast and is read by entity (e.g. all logs for one user)
  // and by action (e.g. all wallet topups in last 24h — used for the rolling
  // cap in adminAddWalletCredit). No indexes meant a full-table scan.
  @@index([entityType, entityId, createdAt])
  @@index([action, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([createdAt])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  ownerUserId String
  createdAt   DateTime @default(now())

  members OrganizationMember[]
}

model OrganizationMember {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           String    // "Owner" | "Admin" | "Member"
  invitedAt      DateTime  @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ShippoLabel {
  id               String    @id @default(cuid())
  userId           String?
  mailItemId       String?
  deliveryOrderId  String?
  transactionId    String    @unique // Shippo transaction ID
  shipmentId       String
  carrier          String    // "USPS" | "UPS" | "FedEx" etc
  servicelevel     String
  trackingNumber   String
  trackingUrl      String
  labelUrl         String
  amountPaid       Float
  currency         String    @default("USD")
  labelFormat      String    @default("PDF")
  status           String    @default("purchased") // "purchased" | "refunded"
  toName           String
  toStreet         String
  toCity           String
  toState          String
  toZip            String
  lengthIn         Float?
  widthIn          Float?
  heightIn         Float?
  weightOz         Float?
  createdAt        DateTime  @default(now())
  refundedAt       DateTime?

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model LabelUpload {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  url         String
  carrier     String?
  trackingNum String?
  notes       String?
  status      String   @default("uploaded") // "uploaded" | "picked_up" | "shipped"
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "mail_arrived" | "package_arrived" | "plan_expiring" | "kyc_approved" | "delivery_update" | "key_ready" | "general"
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?  // optional deep-link in dashboard
  createdAt DateTime @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id           String    @id @default(cuid())
  referrerId   String    // the user who shared their code
  refereeId    String?   // the user who signed up using the code (null until signup)
  code         String    @unique
  status       String    @default("pending") // "pending" | "credited"
  creditCents  Int       @default(1000) // $10 credit for both parties
  createdAt    DateTime  @default(now())
  creditedAt   DateTime?

  referrer User @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)

  // Referrer's "find my own pending code" query (referral.ts) filters by
  // referrerId + refereeId IS NULL. Index speeds the lookup at scale.
  @@index([referrerId, refereeId])
  @@index([refereeId])
}

model BusinessClient {
  id             String    @id @default(cuid())
  name           String
  email          String
  phone          String?
  package        String    @default("Custom")     // "Full Package" | "Formation Only" | "Branding Only" | "Website Only" | "Brand Management" | "Custom"
  stage          String    @default("Intake")      // "Intake" | "In Progress" | "Review" | "Completed" | "Paused"
  progress       Int       @default(0)             // 0-100
  priceCents     Int       @default(0)             // total package price
  paidCents      Int       @default(0)             // what's been paid so far
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model EmailLog {
  id          String    @id @default(cuid())
  userId      String?   // null if sent to non-user (e.g. contact form reply)
  toEmail     String
  fromEmail   String    @default("noreply@nohomailbox.org")
  subject     String
  body        String    // plain-text or HTML body
  kind        String    // "password_reset" | "mail_arrived" | "receipt" | "welcome" | "contact_reply" | "notification" | "other"
  status      String    @default("queued") // "queued" | "sent" | "failed" | "bounced"
  provider    String?   // "resend" | "smtp" | null
  providerId  String?   // provider's message id
  error       String?   // error message if failed
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  // Member dashboard email-history panel + admin email-logs panel both
  // sort by createdAt scoped to a userId. Failed-delivery diagnostic
  // queries filter by status.
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model CancellationRequest {
  id             String    @id @default(cuid())
  userId         String
  reason         String
  status         String    @default("Pending") // "Pending" | "Approved" | "Completed" | "Denied"
  requestedAt    DateTime  @default(now())
  gracePeriodEnd DateTime? // 30 days from approval
  completedAt    DateTime?
  adminNotes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Member requests credits — admin texts a Square payment link, then marks it
// "Paid" which credits the wallet and records a WalletTransaction.
model CreditRequest {
  id            String    @id @default(cuid())
  userId        String
  amountCents   Int       // requested top-up amount
  status        String    @default("Pending") // "Pending" | "LinkSent" | "Paid" | "Cancelled"
  squareLink    String?
  notes         String?
  createdAt     DateTime  @default(now())
  linkSentAt    DateTime?
  paidAt        DateTime?
}

// CMRA quarterly customer-record certification: every 90 days, admin uploads
// a signed PDF (or stores a generated one) per customer attesting that the
// IDs / Form 1583 on file are still valid and mail is being delivered.
model QuarterlyStatement {
  id          String   @id @default(cuid())
  userId      String
  year        Int
  quarter     Int      // 1, 2, 3, 4
  fileUrl     String?  // PDF / image of the signed statement
  periodStart String?  // "2026-01-01"
  periodEnd   String?  // "2026-03-31"
  notes       String?
  uploadedBy  String?  // admin user id
  createdAt   DateTime @default(now())

  @@unique([userId, year, quarter])
  @@index([userId])
}

// Customer pre-pays for a shipping label via the public /shipping page.
// Customer sees Shippo cost + 10% margin. Admin texts a Square link, marks
// paid, then prints the actual Shippo label which is linked back here.
model LabelOrder {
  id                  String    @id @default(cuid())
  userId              String?   // null for guest orders

  // Customer contact (always required)
  customerName        String
  customerEmail       String
  customerPhone       String?

  // Origin: defaults to NOHO store; customers can also have us pick up
  fromKind            String    @default("store") // "store" | "customer"
  fromName            String?
  fromCompany         String?
  fromStreet          String?
  fromCity            String?
  fromState           String?
  fromZip             String?

  // Destination
  toName              String
  toCompany           String?
  toStreet            String
  toCity              String
  toState             String
  toZip               String

  // Parcel
  lengthIn            Float
  widthIn             Float
  heightIn            Float
  weightOz            Float

  // Selected rate snapshot (rate id may expire after ~7 days; we re-fetch if so)
  rateObjectId        String?
  carrier             String    // "USPS" | "UPS" | "FedEx" | "DHL"
  servicelevel        String    // "Priority Mail" | "Ground" etc
  shippoCostCents     Int       // raw Shippo cost (in cents)
  customerPriceCents  Int       // what we charge (Shippo cost x 1.10, rounded)
  marginCents         Int       // customerPriceCents - shippoCostCents
  estimatedDays       Int?

  // Status flow
  status              String    @default("AwaitingPayment") // "AwaitingPayment" | "LinkSent" | "Paid" | "Printed" | "Cancelled"
  squareLink          String?
  linkSentAt          DateTime?
  paidAt              DateTime?
  printedAt           DateTime?
  cancelledAt         DateTime?

  // Linked Shippo label after admin prints (no FK relation to keep schema simple)
  shippoLabelId       String?

  notes               String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}


// Admin-driven mailbox renewal — captures one renewal event with full snapshot
// of plan + dates so receipts can be regenerated and the renewal cleanly
// audited. Receipt is sent via Resend at process time.
model MailboxRenewal {
  id                 String    @id @default(cuid())
  userId             String
  termMonths         Int
  planAtRenewal      String    // snapshot: "Basic" | "Business" | "Premium" etc
  amountCents        Int
  paymentMethod      String    // "Square" | "Cash" | "CardOnFile"
  paidAt             DateTime
  prevPlanDueDate    String?
  newPlanDueDate     String
  prevPlanExpiresAt  DateTime?
  newPlanExpiresAt   DateTime
  receiptSentAt      DateTime?
  receiptEmailLogId  String?
  notes              String?
  createdById        String?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Admin-authored notes attached to a customer — daily CRM activity log.
// "kind" is free-form so admins can categorize ("call", "visit", "compliance",
// "billing", "issue") without locking a taxonomy.
model CustomerNote {
  id          String   @id @default(cuid())
  userId      String
  authorId    String?  // admin user id
  authorName  String?  // snapshot in case admin deleted later
  kind        String   @default("note") // "note" | "call" | "visit" | "compliance" | "billing" | "issue" | "system"
  body        String
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Physical key inventory — every issued / returned / lost key tracked.
// One customer can have multiple keys (master + spare); one key belongs to
// one suite at a time but may be reissued to a new tenant after return.
model MailboxKey {
  id            String    @id @default(cuid())
  keyTag        String    @unique  // physical tag/etching e.g. "K-0142"
  suiteNumber   String
  status        String    @default("InStock") // "InStock" | "Issued" | "Returned" | "Lost" | "Retired"
  issuedToId    String?   // user
  issuedAt      DateTime?
  returnedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([suiteNumber])
  @@index([status])
}

// External referral partner — CPAs, attorneys, web designers, insurance agents.
// Distinct from the customer-to-customer Referral model (above).
model Partner {
  id              String              @id @default(cuid())
  businessName    String
  contactName     String
  email           String              @unique
  phone           String?
  category        String              // "CPA / Bookkeeper" | "Immigration Attorney" | "Business / Corporate Attorney" | "Web Designer / Developer" | "Brand Designer / Agency" | "Insurance Agent" | "Real Estate Agent / Broker" | "Coach / Consultant" | "Other"
  code            String              @unique  // referral code partners share with their clients
  commissionRate  Float               @default(0.15)  // 15% default
  status          String              @default("pending")  // "pending" | "active" | "paused" | "terminated"
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  commissions     PartnerCommission[]

  @@index([code])
  @@index([status])
  @@index([category])
}

// ─── SaaS multi-tenancy ──────────────────────────────────────────────────────
// These three models support licensing the platform to other CMRA operators.
// Initially they exist standalone (no tenantId on existing models yet — v1
// SaaS customers run side-by-side with NOHO Mailbox direct customers).
// Phase 2 will add `tenantId` to User, MailItem, DeliveryOrder, etc.

// A licensed CMRA operator running on the platform.
model Tenant {
  id              String              @id @default(cuid())
  // Display name + slug for subdomain (e.g. "acme" → acme.nohomailbox.org)
  name            String
  slug            String              @unique
  // Owner contact
  ownerName       String
  ownerEmail      String              @unique
  ownerPhone      String?
  // Storefront + branding
  legalAddress    String?             // operator&apos;s storefront address
  legalCity       String?
  legalState      String?
  legalZip        String?
  brandPrimary    String?             // primary brand color hex
  brandLogoUrl    String?             // hosted logo URL (Vercel Blob)
  // Operator status
  status          String              @default("trial") // "trial" | "active" | "paused" | "terminated"
  trialEndsAt     DateTime?
  // SaaS commercial
  tier            String              @default("Solo") // "Solo" | "Multi-Location" | "Enterprise"
  pricePerMonthCents  Int             @default(29900)  // $299 default
  customerCount       Int             @default(0)      // # of CMRA-end-customers (their customers, not ours)
  locationCount       Int             @default(1)
  // Stripe / billing
  stripeCustomerId    String?         @unique
  stripeSubscriptionId String?        @unique
  // Notes
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  subscriptions   TenantSubscription[]
  billingEvents   TenantBillingEvent[]

  @@index([status])
  @@index([tier])
}

// One row per Stripe subscription state-change for audit trail.
model TenantSubscription {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String?
  status            String   // "trialing" | "active" | "past_due" | "canceled" | "unpaid"
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAt          DateTime?
  canceledAt        DateTime?
  // Snapshot pricing at the time
  tier              String
  pricePerMonthCents Int
  createdAt         DateTime @default(now())

  @@index([tenantId])
  @@index([status])
}

// Per-tenant billing event log (charges, refunds, failures).
model TenantBillingEvent {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  kind        String   // "charge_succeeded" | "charge_failed" | "refund" | "subscription_updated" | "subscription_canceled"
  amountCents Int      @default(0)
  currency    String   @default("USD")
  stripeId    String?  // Stripe event/charge id for traceability
  description String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([kind])
}

// Newsletter subscriber list — opt-in only, captured from footer / resources / popup.
model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  source          String    // "footer" | "resources" | "exit-intent" | "blog" | "manual"
  subscribedAt    DateTime  @default(now())
  confirmedAt     DateTime?
  unsubscribedAt  DateTime?
  notes           String?

  @@index([email])
  @@index([subscribedAt])
}

// iter-57: External (non-customer) carrier-pickup dropoffs. The bureau
// acts as an access point for people who already have a pre-paid label
// (USPS Click-N-Ship, FedEx Drop & Go, UPS My Choice, etc.) and just
// need somewhere to leave the package for the carrier to pick up. Not
// a MailItem — it never enters our customer's inbound flow; the package
// belongs to the dropper-offer who brought it in already labeled.
//
// Lifecycle:
//   "Awaiting Carrier" → admin holds it on the outgoing shelf
//   "Picked Up by Carrier" → terminal; carrier swept it that day
//   "Returned" → terminal; couldn't be sent (rare)
//
// All fields beyond tracking + carrier are optional — a typical drop is
// "USPS · 9400 1112 ..." and that's it. Sender/receiver names + photo
// are useful for high-value packages or when the dropper-offer wants a
// printable receipt as proof.
model ExternalDropoff {
  id                String    @id @default(cuid())
  trackingNumber    String
  carrier           String
  senderName        String?    // optional — who's shipping
  senderPhone       String?    // optional — for follow-up if package goes missing
  receiverName      String?    // optional — destination recipient
  destination       String?    // optional free-form: "Phoenix, AZ 85001"
  exteriorImageUrl  String?    // optional Vercel Blob URL
  notes             String?    // free-form admin notes
  status            String     @default("Awaiting Carrier")
  loggedById        String     // admin user who took the dropoff
  carrierPickedUpAt DateTime?  // null until carrier sweep
  createdAt         DateTime   @default(now())

  @@index([status, createdAt])
  @@index([trackingNumber])
  @@index([createdAt])
}

// Each closed referral that earns a partner commission.
model PartnerCommission {
  id              String    @id @default(cuid())
  partnerId       String
  partner         Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  prospectName    String
  prospectEmail   String?
  prospectPhone   String?
  product         String    // "Bundle" | "Retainer" | "Mailbox" | "Delivery" | "Other"
  invoiceCents    Int       @default(0)     // what the customer paid
  commissionCents Int       @default(0)     // what the partner earns
  status          String    @default("lead")  // "lead" | "quoted" | "closed" | "cancelled" | "paid"
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?
  paidAt          DateTime?

  @@index([partnerId])
  @@index([status])
}

// ─── POS / Cash Register ─────────────────────────────────────────────────
// Counter-side point-of-sale for one-off, walk-in, or augmenting transactions
// (mailbox renewals, supplies, notary, key replacement, custom items, tips).
// Distinct from MailboxRenewal (renewal-only flow) and Payment (Square sync
// snapshot) so the register has its own auditable line-item ledger.
model POSSale {
  id              String        @id @default(cuid())
  number          Int           @unique   // human-friendly receipt # — assigned at create time
  cashierId       String?       // admin who rang it up (snapshot)
  cashierName     String?
  customerId      String?       // optional — links to User (for member discount, wallet credit)
  customerName    String?       // snapshot for receipt
  customerPhone   String?
  customerEmail   String?
  customerSuite   String?

  // Money — all in cents
  subtotalCents   Int           @default(0)
  discountCents   Int           @default(0)
  taxCents        Int           @default(0)
  tipCents        Int           @default(0)
  totalCents      Int           @default(0)

  // Cash specifics
  cashTenderedCents Int?         // amount handed over (for change calc)
  cashChangeCents   Int?         // change due back

  // Payment
  paymentMethod   String        // "Cash" | "Zelle" | "Square" | "CardOnFile" | "Wallet" | "Custom"
  customMethodLabel String?     // when paymentMethod = "Custom" (e.g. "Venmo", "Check #1042", "ACH")
  paymentRef      String?       // Square payment id / Zelle confirm code / check #
  zelleEmail      String?       // snapshot of nohomailbox@gmail.com for receipt copy

  // Lifecycle
  status          String        @default("Open")  // "Open" | "Paid" | "Voided" | "Refunded"
  paidAt          DateTime?
  voidedAt        DateTime?
  voidReason      String?
  refundedAt      DateTime?
  refundReason    String?

  // Receipt copies
  receiptPrintedAt DateTime?
  receiptEmailedAt DateTime?
  receiptSmsedAt   DateTime?

  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer User?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    POSLineItem[]

  @@index([customerId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([cashierId])
}

model POSLineItem {
  id            String   @id @default(cuid())
  saleId        String
  // Product snapshot
  sku           String?  // optional SKU for catalog item; null for custom line
  name          String   // display name on receipt
  category      String?  // "Mailbox" | "Supplies" | "Service" | "Notary" | "Shipping" | "Custom" | "Tip"
  unitPriceCents Int     // price per unit at time of sale
  quantity      Int      @default(1)
  discountCents Int      @default(0) // line-level discount
  taxCents      Int      @default(0)
  totalCents    Int      // (unitPriceCents * quantity) - discountCents + taxCents
  // For mailbox renewals rung up via POS, link back to the renewal record
  linkedRenewalId String?
  // Original notes / serial / variant
  notes         String?
  createdAt     DateTime @default(now())

  sale POSSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([sku])
}

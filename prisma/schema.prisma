// iter-84: Per-message SMS log. Mirrors EmailLog shape so tooling can
// reason about both delivery channels uniformly. SMS uses Twilio when
// TWILIO_* env vars are configured; otherwise we still log so admin sees
// the attempt + the body that would've gone out.
//
// iter-163: `bulkBatchId` groups every SMS sent inside a single bulk
// campaign so admin can drill from BulkSmsCampaign → its individual
// per-recipient logs.
model SmsLog {
  id          String    @id @default(cuid())
  userId      String?
  toPhone     String    // E.164 if normalized; raw otherwise
  fromPhone   String?
  body        String
  kind        String    // "mail_arrived" | "package_picked_up" | "storage_warning" | "bulk" | "verification" | ...
  status      String    @default("queued") // "queued" | "sent" | "failed" | "not_sent"
  provider    String?   // "twilio" | null
  providerId  String?   // Twilio SID
  error       String?
  segments    Int?      // Twilio reports segment count for billing
  bulkBatchId String?   // iter-163: links to BulkSmsCampaign.id for grouping
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([bulkBatchId])
}

// iter-163: Bulk SMS campaign roll-up record. Mirrors the `mailer.bulk_send`
// audit-log pattern but lives as its own queryable row so admin can list
// past campaigns, see succeeded/failed counts, and (later) re-run.
//
// `audienceJson` is the verbatim audience selector (kind + filter) so
// the panel can show what filter was used. `body` is the rendered text
// before per-recipient {{firstName}} / {{suiteNumber}} substitution.
//
// Per-recipient SmsLog rows carry `bulkBatchId = campaign.id` for drill
// down. Idempotent on `id` (the panel passes a fresh cuid per send;
// dryRun + test sends do NOT create a campaign row).
model BulkSmsCampaign {
  id              String    @id @default(cuid())
  label           String    // human-readable name e.g. "Holiday hours reminder"
  body            String    // raw template body (with {{firstName}} placeholders)
  audienceJson    String    // JSON-stringified MailerAudience
  recipientCount  Int       // total resolved members
  succeededCount  Int       @default(0)
  failedCount     Int       @default(0)
  notSentCount    Int       @default(0)  // Twilio not configured / phone unparseable
  estSegments     Int       @default(0)  // sum of body segments × recipients (cost preview)
  sentById        String?
  sentAt          DateTime  @default(now())

  @@index([sentAt])
  @@index([sentById])
}

model CancellationRequest {
  id             String    @id @default(cuid())
  userId         String
  reason         String
  status         String    @default("Pending") // "Pending" | "Approved" | "Completed" | "Denied"
  requestedAt    DateTime  @default(now())
  gracePeriodEnd DateTime? // 30 days from approval
  completedAt    DateTime?
  adminNotes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Member requests credits — admin texts a Square payment link, then marks it
// "Paid" which credits the wallet and records a WalletTransaction.
model CreditRequest {
  id            String    @id @default(cuid())
  userId        String
  amountCents   Int       // requested top-up amount
  status        String    @default("Pending") // "Pending" | "LinkSent" | "Paid" | "Cancelled"
  squareLink    String?
  notes         String?
  createdAt     DateTime  @default(now())
  linkSentAt    DateTime?
  paidAt        DateTime?
}

// CMRA quarterly customer-record certification: every 90 days, admin uploads
// a signed PDF (or stores a generated one) per customer attesting that the
// IDs / Form 1583 on file are still valid and mail is being delivered.
model QuarterlyStatement {
  id          String   @id @default(cuid())
  userId      String
  year        Int
  quarter     Int      // 1, 2, 3, 4
  fileUrl     String?  // PDF / image of the signed statement
  periodStart String?  // "2026-01-01"
  periodEnd   String?  // "2026-03-31"
  notes       String?
  uploadedBy  String?  // admin user id
  createdAt   DateTime @default(now())

  @@unique([userId, year, quarter])
  @@index([userId])
}

// Customer pre-pays for a shipping label via the public /shipping page.
// Customer sees Shippo cost + 10% margin. Admin texts a Square link, marks
// paid, then prints the actual Shippo label which is linked back here.
model LabelOrder {
  id                  String    @id @default(cuid())
  userId              String?   // null for guest orders

  // Customer contact (always required)
  customerName        String
  customerEmail       String
  customerPhone       String?

  // Origin: defaults to NOHO store; customers can also have us pick up
  fromKind            String    @default("store") // "store" | "customer"
  fromName            String?
  fromCompany         String?
  fromStreet          String?
  fromCity            String?
  fromState           String?
  fromZip             String?

  // Destination
  toName              String
  toCompany           String?
  toStreet            String
  toCity              String
  toState             String
  toZip               String

  // Parcel
  lengthIn            Float
  widthIn             Float
  heightIn            Float
  weightOz            Float

  // Selected rate snapshot (rate id may expire after ~7 days; we re-fetch if so)
  rateObjectId        String?
  carrier             String    // "USPS" | "UPS" | "FedEx" | "DHL"
  servicelevel        String    // "Priority Mail" | "Ground" etc
  shippoCostCents     Int       // raw Shippo cost (in cents)
  customerPriceCents  Int       // what we charge (Shippo cost x 1.10, rounded)
  marginCents         Int       // customerPriceCents - shippoCostCents
  estimatedDays       Int?

  // Status flow
  status              String    @default("AwaitingPayment") // "AwaitingPayment" | "LinkSent" | "Paid" | "Printed" | "Cancelled"
  squareLink          String?
  linkSentAt          DateTime?
  paidAt              DateTime?
  printedAt           DateTime?
  cancelledAt         DateTime?

  // Linked Shippo label after admin prints (no FK relation to keep schema simple)
  shippoLabelId       String?

  notes               String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}


// Admin-driven mailbox renewal — captures one renewal event with full snapshot
// of plan + dates so receipts can be regenerated and the renewal cleanly
// audited. Receipt is sent via Resend at process time.
model MailboxRenewal {
  id                 String    @id @default(cuid())
  userId             String
  termMonths         Int
  planAtRenewal      String    // snapshot: "Basic" | "Business" | "Premium" etc
  amountCents        Int
  paymentMethod      String    // "Square" | "Cash" | "CardOnFile"
  paidAt             DateTime
  prevPlanDueDate    String?
  newPlanDueDate     String
  prevPlanExpiresAt  DateTime?
  newPlanExpiresAt   DateTime
  receiptSentAt      DateTime?
  receiptEmailLogId  String?
  notes              String?
  createdById        String?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Admin-authored notes attached to a customer — daily CRM activity log.
// "kind" is free-form so admins can categorize ("call", "visit", "compliance",
// "billing", "issue") without locking a taxonomy.
model CustomerNote {
  id          String   @id @default(cuid())
  userId      String
  authorId    String?  // admin user id
  authorName  String?  // snapshot in case admin deleted later
  kind        String   @default("note") // "note" | "call" | "visit" | "compliance" | "billing" | "issue" | "system"
  body        String
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Physical key inventory — every issued / returned / lost key tracked.
// One customer can have multiple keys (master + spare); one key belongs to
// one suite at a time but may be reissued to a new tenant after return.
model MailboxKey {
  id            String    @id @default(cuid())
  keyTag        String    @unique  // physical tag/etching e.g. "K-0142"
  suiteNumber   String
  status        String    @default("InStock") // "InStock" | "Issued" | "Returned" | "Lost" | "Retired"
  issuedToId    String?   // user
  issuedAt      DateTime?
  returnedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([suiteNumber])
  @@index([status])
}

// External referral partner — CPAs, attorneys, web designers, insurance agents.
// Distinct from the customer-to-customer Referral model (above).
model Partner {
  id              String              @id @default(cuid())
  businessName    String
  contactName     String
  email           String              @unique
  phone           String?
  category        String              // "CPA / Bookkeeper" | "Immigration Attorney" | "Business / Corporate Attorney" | "Web Designer / Developer" | "Brand Designer / Agency" | "Insurance Agent" | "Real Estate Agent / Broker" | "Coach / Consultant" | "Other"
  code            String              @unique  // referral code partners share with their clients
  commissionRate  Float               @default(0.15)  // 15% default
  status          String              @default("pending")  // "pending" | "active" | "paused" | "terminated"
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  commissions     PartnerCommission[]

  @@index([code])
  @@index([status])
  @@index([category])
}

// ─── SaaS multi-tenancy ──────────────────────────────────────────────────────
// These three models support licensing the platform to other CMRA operators.
// Initially they exist standalone (no tenantId on existing models yet — v1
// SaaS customers run side-by-side with NOHO Mailbox direct customers).
// Phase 2 will add `tenantId` to User, MailItem, DeliveryOrder, etc.

// A licensed CMRA operator running on the platform.
model Tenant {
  id              String              @id @default(cuid())
  // Display name + slug for subdomain (e.g. "acme" → acme.nohomailbox.org)
  name            String
  slug            String              @unique
  // Owner contact
  ownerName       String
  ownerEmail      String              @unique
  ownerPhone      String?
  // Storefront + branding
  legalAddress    String?             // operator&apos;s storefront address
  legalCity       String?
  legalState      String?
  legalZip        String?
  brandPrimary    String?             // primary brand color hex
  brandLogoUrl    String?             // hosted logo URL (Vercel Blob)
  // Operator status
  status          String              @default("trial") // "trial" | "active" | "paused" | "terminated"
  trialEndsAt     DateTime?
  // SaaS commercial
  tier            String              @default("Solo") // "Solo" | "Multi-Location" | "Enterprise"
  pricePerMonthCents  Int             @default(29900)  // $299 default
  customerCount       Int             @default(0)      // # of CMRA-end-customers (their customers, not ours)
  locationCount       Int             @default(1)
  // Stripe / billing
  stripeCustomerId    String?         @unique
  stripeSubscriptionId String?        @unique
  // Notes
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  subscriptions   TenantSubscription[]
  billingEvents   TenantBillingEvent[]

  @@index([status])
  @@index([tier])
}

// One row per Stripe subscription state-change for audit trail.
model TenantSubscription {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String?
  status            String   // "trialing" | "active" | "past_due" | "canceled" | "unpaid"
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAt          DateTime?
  canceledAt        DateTime?
  // Snapshot pricing at the time
  tier              String
  pricePerMonthCents Int
  createdAt         DateTime @default(now())

  @@index([tenantId])
  @@index([status])
}

// Per-tenant billing event log (charges, refunds, failures).
model TenantBillingEvent {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  kind        String   // "charge_succeeded" | "charge_failed" | "refund" | "subscription_updated" | "subscription_canceled"
  amountCents Int      @default(0)
  currency    String   @default("USD")
  stripeId    String?  // Stripe event/charge id for traceability
  description String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([kind])
}

// Newsletter subscriber list — opt-in only, captured from footer / resources / popup.
model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  source          String    // "footer" | "resources" | "exit-intent" | "blog" | "manual"
  subscribedAt    DateTime  @default(now())
  confirmedAt     DateTime?
  unsubscribedAt  DateTime?
  notes           String?

  @@index([email])
  @@index([subscribedAt])
}

// iter-94: Per-package carrier tracking events polled from Shippo.
// One row per (mailItemId, eventTimeIso, statusKey) so a re-poll
// doesn't insert duplicates. Used for member dashboard "out for
// delivery" + public timeline + admin row signal.
model TrackingEvent {
  id            String   @id @default(cuid())
  mailItemId    String
  eventTimeIso  String   // raw timestamp from carrier (string for dedup key reliability)
  statusKey     String   // normalized: "delivered" | "out_for_delivery" | "in_transit" | "exception" | ...
  statusDetails String   // human-friendly label, e.g. "Out for delivery"
  location      String?  // "Burbank, CA"
  source        String   // "shippo" | "manual" | future "usps" | "ups" | "fedex"
  createdAt     DateTime @default(now())

  @@unique([mailItemId, eventTimeIso, statusKey])
  @@index([mailItemId, createdAt])
}

// Per-MailItem polling state — when did we last hit the carrier API.
// Separate from TrackingEvent so polling cadence isn't coupled to
// whether new events were returned.
model MailItemTrackingState {
  mailItemId         String    @id
  lastPolledAt       DateTime?
  lastStatusKey      String?
  lastStatusLabel    String?
  lastLocation       String?
  etaIso             String?   // ISO timestamp from carrier ETA
  pollErrorCount     Int       @default(0)
  pollLastError      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([lastPolledAt])
}

// iter-92: One-tap NPS-ish pickup feedback. Created when admin marks a
// MailItem as Picked Up. The customer gets a unique token-gated URL in
// the pickup-confirm email; submitting flips submittedAt and stores
// rating + comment. Anonymous submission allowed (we know the userId
// from the token).
model PickupSurvey {
  id          String    @id @default(cuid())
  mailItemId  String    @unique
  userId      String
  token       String    @unique  // long random URL-safe token
  rating      Int?      // 1..5, null until submitted
  comment     String?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([submittedAt])
}

// iter-57: External (non-customer) carrier-pickup dropoffs. The bureau
// acts as an access point for people who already have a pre-paid label
// (USPS Click-N-Ship, FedEx Drop & Go, UPS My Choice, etc.) and just
// need somewhere to leave the package for the carrier to pick up. Not
// a MailItem — it never enters our customer's inbound flow; the package
// belongs to the dropper-offer who brought it in already labeled.
//
// Lifecycle:
//   "Awaiting Carrier" → admin holds it on the outgoing shelf
//   "Picked Up by Carrier" → terminal; carrier swept it that day
//   "Returned" → terminal; couldn't be sent (rare)
//
// All fields beyond tracking + carrier are optional — a typical drop is
// "USPS · 9400 1112 ..." and that's it. Sender/receiver names + photo
// are useful for high-value packages or when the dropper-offer wants a
// printable receipt as proof.
model ExternalDropoff {
  id                String    @id @default(cuid())
  trackingNumber    String
  carrier           String
  senderName        String?    // optional — who's shipping
  senderPhone       String?    // optional — for follow-up if package goes missing
  receiverName      String?    // optional — destination recipient
  destination       String?    // optional free-form: "Phoenix, AZ 85001"
  exteriorImageUrl  String?    // optional Vercel Blob URL
  notes             String?    // free-form admin notes
  status            String     @default("Awaiting Carrier")
  loggedById        String     // admin user who took the dropoff
  carrierPickedUpAt DateTime?  // null until carrier sweep
  createdAt         DateTime   @default(now())

  @@index([status, createdAt])
  @@index([trackingNumber])
  @@index([createdAt])
}

// Each closed referral that earns a partner commission.
model PartnerCommission {
  id              String    @id @default(cuid())
  partnerId       String
  partner         Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  prospectName    String
  prospectEmail   String?
  prospectPhone   String?
  product         String    // "Bundle" | "Retainer" | "Mailbox" | "Delivery" | "Other"
  invoiceCents    Int       @default(0)     // what the customer paid
  commissionCents Int       @default(0)     // what the partner earns
  status          String    @default("lead")  // "lead" | "quoted" | "closed" | "cancelled" | "paid"
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?
  paidAt          DateTime?

  @@index([partnerId])
  @@index([status])
}

// ─── POS / Cash Register ─────────────────────────────────────────────────
// Counter-side point-of-sale for one-off, walk-in, or augmenting transactions
// (mailbox renewals, supplies, notary, key replacement, custom items, tips).
// Distinct from MailboxRenewal (renewal-only flow) and Payment (Square sync
// snapshot) so the register has its own auditable line-item ledger.
model POSSale {
  id              String        @id @default(cuid())
  number          Int           @unique   // human-friendly receipt # — assigned at create time
  cashierId       String?       // admin who rang it up (snapshot)
  cashierName     String?
  customerId      String?       // optional — links to User (for member discount, wallet credit)
  customerName    String?       // snapshot for receipt
  customerPhone   String?
  customerEmail   String?
  customerSuite   String?

  // Money — all in cents
  subtotalCents   Int           @default(0)
  discountCents   Int           @default(0)
  taxCents        Int           @default(0)
  tipCents        Int           @default(0)
  totalCents      Int           @default(0)

  // Cash specifics
  cashTenderedCents Int?         // amount handed over (for change calc)
  cashChangeCents   Int?         // change due back

  // Payment
  paymentMethod   String        // "Cash" | "Zelle" | "Square" | "CardOnFile" | "Wallet" | "Custom"
  customMethodLabel String?     // when paymentMethod = "Custom" (e.g. "Venmo", "Check #1042", "ACH")
  paymentRef      String?       // Square payment id / Zelle confirm code / check #
  zelleEmail      String?       // snapshot of nohomailbox@gmail.com for receipt copy

  // Lifecycle
  status          String        @default("Open")  // "Open" | "Paid" | "Voided" | "Refunded"
  paidAt          DateTime?
  voidedAt        DateTime?
  voidReason      String?
  refundedAt      DateTime?
  refundReason    String?

  // Receipt copies
  receiptPrintedAt DateTime?
  receiptEmailedAt DateTime?
  receiptSmsedAt   DateTime?

  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer User?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    POSLineItem[]

  @@index([customerId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([cashierId])
}

model POSLineItem {
  id            String   @id @default(cuid())
  saleId        String
  // Product snapshot
  sku           String?  // optional SKU for catalog item; null for custom line
  name          String   // display name on receipt
  category      String?  // "Mailbox" | "Supplies" | "Service" | "Notary" | "Shipping" | "Custom" | "Tip"
  unitPriceCents Int     // price per unit at time of sale
  quantity      Int      @default(1)
  discountCents Int      @default(0) // line-level discount
  taxCents      Int      @default(0)
  totalCents    Int      // (unitPriceCents * quantity) - discountCents + taxCents
  // For mailbox renewals rung up via POS, link back to the renewal record
  linkedRenewalId String?
  // Original notes / serial / variant
  notes         String?
  createdAt     DateTime @default(now())

  sale POSSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([sku])
}

// ─── iter-235 — Member-curated lobby playlist ──────────────────────────
// Opted-in members suggest songs for the bureau lobby speakers + vote
// for their favorites. Top 25 by votes display on the public
// `/lobby/playlist` "NOHO TV" page that runs on the lobby monitor.
// Admin can hide inappropriate suggestions.

model LobbyPlaylistSong {
  id                String   @id @default(cuid())
  suggestedById     String
  suggestedByName   String?                                  // snapshot at submission time
  suggestedBySuite  String?
  title             String
  artist            String
  link              String?                                  // YouTube / Spotify / Apple Music URL
  notes             String?                                  // member's optional "why this song" (≤120 chars)
  votesCount        Int      @default(1)                     // denormalized; bumped on vote insert (1 = self-vote at submit)
  hiddenAt          DateTime?
  hiddenReason      String?
  hiddenById        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user  User                @relation(fields: [suggestedById], references: [id], onDelete: Cascade)
  votes LobbyPlaylistVote[]

  @@index([hiddenAt, votesCount])
  @@index([suggestedById, createdAt])
}

model LobbyPlaylistVote {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song LobbyPlaylistSong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
  @@index([userId, createdAt])
}

// ─── iter-234 — Smart fraud detection ──────────────────────────────────
// Pure-rules detector that scans recent MailItems + intake patterns
// against 6 fraud signals (high-volume same-sender, suspended-account
// activity, low-KYC-trust + high-value, recipient-name mismatch, cross-
// suite tracking dupes, new-account spike) and writes FraudFlag rows
// for admin review. Idempotent via `@@unique([signalKey])` so re-runs
// don't dupe.
//
// Reuses iter-227 pure-rules + cron-sweep pattern + iter-228-style
// atomic prisma.$transaction([entity.update, audit]).

model FraudFlag {
  id             String   @id @default(cuid())
  signalKey      String   @unique                 // dedup key, e.g. "high_volume_sender:KARIM_AMAZON:2026-W19"
  signalType     String                            // "high_volume_sender" | "suspended_account_activity" | "low_kyc_high_value" | "recipient_mismatch" | "cross_suite_tracking" | "new_account_spike"
  severity       String                            // "low" | "medium" | "high" | "critical"
  entityType     String                            // "User" | "MailItem" | "Suite"
  entityId       String                            // primary entity referenced (User.id, MailItem.id, suite#)
  userId         String?                           // affected member (for user-side filters)
  suiteNumber    String?                           // affected suite #
  summary        String                            // 1-line human-readable summary
  detailJson     String                            // structured detail (counts, refs, scores)
  evidenceCount  Int       @default(1)             // # of items / events evidencing the flag
  status         String    @default("Open")        // "Open" | "Reviewed" | "Dismissed" | "Escalated"
  reviewedAt     DateTime?
  reviewedById   String?
  reviewNote     String?
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, severity, firstSeenAt])
  @@index([signalType, status])
  @@index([userId, status])
  @@index([suiteNumber, status])
}

// ─── iter-233 — Address-of-record auto-update ──────────────────────────
// Member curates a list of orgs that need to know their address (banks,
// schools, employers, subscriptions, government). When their iter-129
// ForwardingAddress changes — or any time on demand — they trigger a
// "notice run" that emails each org with a templated address-change
// letter. Postal-only contacts get a letter pre-generated for admin to
// drop in the mail manually.
//
// Reuses iter-228 atomic prisma.$transaction([entity.update, audit])
// and iter-225-style fire-and-forget post-tx email side effects.

model AddressNotificationContact {
  id              String   @id @default(cuid())
  userId          String
  label           String                              // "Chase Bank", "Stanford Alumni", "Apple HR"
  category        String?                             // "bank" | "school" | "employer" | "government" | "subscription" | "insurance" | "other"
  contactEmail    String?                             // canonical lowercase
  contactPostal   String?                             // multi-line postal address; null if email-only
  accountNumber   String?                             // optional, e.g. "Account ending 4421"
  notes           String?                             // member-only memo
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([userId, category])
}

model AddressChangeNoticeRun {
  id                  String   @id @default(cuid())
  userId              String
  triggeredFromAddrId String?                        // FK ForwardingAddress.id when launched from a saved address change
  oldAddressBody      String?                        // snapshot of the prior address text (optional)
  newAddressBody      String                         // snapshot of the new address (multi-line)
  effectiveDate       String?                        // YYYY-MM-DD
  noticeMessage       String?                        // member's optional personal note added to each notice
  contactsTotal       Int      @default(0)
  emailsSent          Int      @default(0)
  postalGenerated     Int      @default(0)
  status              String   @default("Pending")   // "Pending" | "Running" | "Completed" | "Cancelled"
  createdAt           DateTime @default(now())
  completedAt         DateTime?

  user  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items AddressChangeNoticeItem[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AddressChangeNoticeItem {
  id              String   @id @default(cuid())
  runId           String
  contactId       String?                            // FK to source contact (snapshots below in case it gets edited later)
  contactLabel    String
  contactCategory String?
  channel         String                             // "email" | "postal"
  recipient       String                             // email address OR multi-line postal address
  accountNumber   String?                            // snapshot at run time
  status          String   @default("queued")       // "queued" | "sent" | "failed" | "mailed" | "skipped"
  error           String?
  emailLogId      String?                            // FK EmailLog.id when channel=email
  sentAt          DateTime?                          // emails: provider-acked; postal: when admin marked mailed
  createdAt       DateTime @default(now())

  run AddressChangeNoticeRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, status])
  @@index([channel, status])
}

// ─── iter-231 — Self-serve mailbox transfer to family ──────────────────
// Member-initiated handover of an entire mailbox account to a family
// member (spouse, child, parent, sibling). Workflow:
//   1. Member files request with recipient email + name + relationship
//   2. System emails recipient with "visit the bureau in person" CTA
//      (per KHIARI no-e-sign rule), emails primary user a confirmation
//   3. Admin verifies KYC docs + Form 1583 in person, uploads scans
//   4. Admin Approves → atomic: revoke all iter-100 SharedMailboxAccess
//      held by the primary user (snapshot revoked IDs onto the row),
//      audit, send completion emails, fire webhook
//   5. Admin manually creates the new User account + Completes the
//      transfer (links to the new User.id snapshot for audit trail)
//
// Distinct from iter-122 SuiteTransferRequest (which is just changing
// the suite # for the same member); this is a true ownership change.

model MailboxFamilyTransfer {
  id                          String    @id @default(cuid())
  primaryUserId               String
  primaryUserName             String?                       // snapshot
  primaryUserSuite            String?                       // snapshot
  primaryUserEmail            String?                       // snapshot

  recipientEmail              String                         // canonical lowercase
  recipientName               String
  recipientPhone              String?
  relationship                String                         // "spouse" | "child" | "parent" | "sibling" | "other"
  reason                      String?                        // member's note

  // Admin-uploaded after in-person visit
  kycIdImageUrl               String?
  kycForm1583Url              String?
  kycNotes                    String?
  visitedBureauAt             DateTime?

  status                      String    @default("Pending") // "Pending" | "AwaitingVisit" | "Approved" | "Completed" | "Cancelled" | "Denied"
  approvedAt                  DateTime?
  approvedById                String?
  decisionNote                String?
  completedAt                 DateTime?
  newUserId                   String?                        // FK snapshot of recipient's User row when admin creates it
  cancelledAt                 DateTime?
  cancelledReason             String?
  deniedAt                    DateTime?
  deniedReason                String?

  // Snapshot of revoked SharedMailboxAccess IDs at approval time
  revokedSharedAccessIdsJson  String?

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  primaryUser                 User      @relation(fields: [primaryUserId], references: [id], onDelete: Cascade)

  @@index([primaryUserId, status])
  @@index([status, createdAt])
  @@index([recipientEmail])
}

// ─── iter-230 — Forwarding cost-share split ────────────────────────────
// When ≥2 members are forwarding to the same destination address, an
// admin can batch them into one combined shipment and split the postage
// savings (totalIndividualCost − combinedCost) evenly back to each
// member's wallet (WalletTransaction kind="Refund"). Each split is
// audited + a `forwarding.cost_share_split` webhook fires for ops
// visibility.
//
// Members also see the credit on their wallet history with a clear
// description: "Forwarding cost-share · NYC 10128 · saved $4.25 with 2
// neighbors".

model ForwardingCostShareGroup {
  id                    String   @id @default(cuid())
  destAddressHash       String                                   // normalized "{zip}|{streetTokens}" — used to match suggestions
  destAddressLabel      String                                   // human-readable address snapshot at create time
  destCity              String?
  destState             String?
  destZip               String?
  carrier               String?                                  // "USPS" | "UPS" | "FedEx" | "DHL" | null
  trackingNumber        String?                                  // assigned at approval/ship time
  totalIndividualCents  Int                                      // sum of what each member would have paid alone
  combinedPostageCents  Int                                      // actual combined-shipment cost
  savingsCents          Int      @default(0)                     // totalIndividual - combined
  perMemberCreditCents  Int      @default(0)                     // floor(savings / memberCount)
  status                String   @default("Suggested")           // "Suggested" | "Approved" | "Shipped" | "Cancelled"
  notes                 String?
  approvedAt            DateTime?
  approvedById          String?
  shippedAt             DateTime?
  cancelledAt           DateTime?
  cancelledReason       String?
  createdAt             DateTime @default(now())
  createdById           String

  members               ForwardingCostShareMember[]

  @@index([status, createdAt])
  @@index([destAddressHash, createdAt])
}

model ForwardingCostShareMember {
  id                    String   @id @default(cuid())
  groupId               String
  userId                String
  userNameSnapshot      String?
  suiteSnapshot         String?
  individualPostageCents Int                                     // what they would have paid solo
  creditCents           Int      @default(0)                     // applied at approval (== group.perMemberCreditCents at that time)
  walletTxnId           String?                                  // link to the WalletTransaction created at split
  createdAt             DateTime @default(now())

  group                 ForwardingCostShareGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, createdAt])
}

// ─── iter-229 — Cash-drawer reconciliation ─────────────────────────────
// Daily cash-drawer session: admin opens with a counted starting float,
// rings POS sales through the shift, logs paid-in/paid-out cash
// adjustments (petty cash, supply runs, refunds outside POS), then
// closes with a counted ending cash count. Server computes
// expected = openingCents + cashSalesCents - cashRefundsCents + sum(adjustments)
// and surfaces the signed variance vs the counted closingCents.
// Sessions with |variance| > tolerance are flagged "Variance" until
// admin signs off (with a reason memo) — and emit a webhook +
// audit-log breadcrumb for compliance.

model CashDrawerSession {
  id                    String   @id @default(cuid())
  number                Int      @unique     // human-friendly session # (auto-increment)
  stationLabel          String?              // optional: "Front desk", "Back office"
  openingCents          Int                  // counted starting cash float
  openedAt              DateTime @default(now())
  openedById            String                // admin who opened
  openedByName          String?               // snapshot

  // Computed at close (denormalized for fast dashboard reads)
  cashSalesCents        Int      @default(0)  // sum of cash POSSale totals during window
  cashRefundsCents      Int      @default(0)  // sum of cash refunds during window
  adjustmentsCents      Int      @default(0)  // sum of (paid_in - paid_out) adjustments
  expectedClosingCents  Int      @default(0)  // opening + sales - refunds + adjustments
  closingCents          Int?                  // counted ending float
  varianceCents         Int?                  // closingCents - expectedClosingCents (signed)
  varianceFlagged       Boolean  @default(false)
  varianceTolerance     Int      @default(500) // 5.00 USD default tolerance
  closeNote             String?               // free-form memo at close
  signOffReason         String?               // if flagged, admin's explanation
  signedOffAt           DateTime?
  signedOffById         String?
  closedAt              DateTime?
  closedById            String?
  closedByName          String?

  status                String   @default("Open") // "Open" | "Closed" | "Variance"
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  adjustments           CashDrawerAdjustment[]

  @@index([status, openedAt])
  @@index([openedById])
  @@index([closedAt])
}

model CashDrawerAdjustment {
  id            String   @id @default(cuid())
  sessionId     String
  kind          String                          // "paid_in" | "paid_out"
  amountCents   Int                             // always positive — sign comes from kind
  reason        String                          // mandatory short reason
  category      String?                         // "petty_cash" | "supply_run" | "refund_external" | "deposit" | "other"
  receiptRef    String?                         // optional receipt # / vendor / check #
  byActorId     String
  byActorName   String?
  createdAt     DateTime @default(now())

  session       CashDrawerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([kind, createdAt])
}

// ─── AI Assistant agent (iter 10) ───────────────────────────────────────
//
// Conversations + messages for the admin AI Assistant. Each conversation
// is owned by an admin User and contains an ordered list of messages
// (system / user / assistant / tool roles). Tool calls and tool results
// are stored as messages with `toolName` / `toolInput` / `toolResult`.
//
// AgentMemory is a lightweight persistent note store the agent uses as a
// "long-term memory" — entries get loaded into the system prompt on every
// turn so the agent accumulates project context across sessions.

model AgentConversation {
  id          String   @id
  ownerId     String
  title       String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([ownerId, updatedAt])
}

model AgentMessage {
  id              String   @id
  conversationId  String
  role            String   // "user" | "assistant" | "system" | "tool"
  content         String   // for user/assistant: plain text; for tool messages: JSON-stringified
  toolName        String?  // for tool calls: the requested tool name
  toolInput       String?  // JSON-stringified arguments
  toolResult      String?  // JSON-stringified result (set when the user approves + the tool runs)
  toolStatus      String?  // "pending" | "approved" | "rejected" | "executed" | "failed"
  toolError       String?  // error message if status=failed
  inputTokens     Int?     // accounting
  outputTokens    Int?
  cacheReadTokens Int?
  createdAt       DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([toolStatus])
}

model AgentMemory {
  id        String   @id
  // Scope: "global" loads on every conversation; otherwise the conversation id.
  scope     String   @default("global")
  // Free-text key the agent uses to organize. e.g. "brand-book",
  // "customer-roster-summary", "iteration-history".
  key       String
  body      String   // The memory itself, max ~8KB recommended
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, key])
  @@index([pinned])
}

// iter-169 — CotM marketing spotlight (Tier 11 #78).
// When a member is awarded Customer of the Month (iter-152), they can
// opt in to a homepage spotlight card on nohomailbox.org showcasing
// their business + a 1-sentence quote + photo. Powerful social proof
// for marketing without ever publishing PII the member didn't provide
// themselves.
//
// Lifecycle: award created → member sees opt-in CTA → fills 3-field
// form → row created with `status="pending"` → admin reviews + flips
// to "published" → marketing homepage shows the card → member can
// retract anytime via `status="retracted"`. Only ONE published slot
// shows on the homepage at a time (most recent published).
model CotmMarketingSlot {
  id              String   @id @default(cuid())
  awardId         String   @unique               // 1:1 with the award row — can't have two spotlights for one win
  userId          String                          // denormalized for member-side queries + display name
  status          String   @default("pending")    // "pending" | "published" | "retracted" | "rejected"
  businessName    String                          // member-supplied display name (can differ from User.name)
  quote           String                          // 1 sentence, ≤200 chars
  photoUrl        String?                         // member-uploaded headshot/logo
  websiteUrl      String?                         // optional link to their site
  publishedAt     DateTime?                       // when admin flipped to published
  publishedById   String?                         // admin who approved
  retractedAt     DateTime?                       // when member opted out
  rejectedAt      DateTime?                       // when admin rejected
  rejectionReason String?                         // shown to member if rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  award           CustomerOfMonthAward @relation(fields: [awardId], references: [id], onDelete: Cascade)
  user            User                 @relation("CotmMarketingSlotUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, publishedAt])
  @@index([userId])
}

// iter-168 — Sender thank-you notes (Tier 11 #77).
// Anyone with the public-share link from iter-93 can scan the QR on a
// package's exterior + leave a short note that lands in the recipient's
// dashboard. No auth required; rate-limited per IP via the action.
//
// Sender details (name/email) are optional — packages have no
// guaranteed sender PII at intake, so the sender themselves fills in
// who they are. The recipient sees the note under their package detail
// + gets a notification ping the moment it lands.
model SenderThankYou {
  id           String   @id @default(cuid())
  mailItemId   String
  senderName   String?              // free-text, optional
  senderEmail  String?              // optional, validated when present
  message      String               // 1-500 chars
  ip           String?              // diagnostic only — never displayed
  userAgent    String?              // diagnostic only
  hidden       Boolean  @default(false)  // recipient can hide spammy notes
  createdAt    DateTime @default(now())

  mailItem     MailItem @relation(fields: [mailItemId], references: [id], onDelete: Cascade)

  @@index([mailItemId, createdAt])
  @@index([createdAt])
}

// iter-167 — Member-registered webhooks (Tier 11 #76).
// Counterpart to iter-104 admin-side `WebhookEndpoint`. Each member can
// register their OWN URL to receive their OWN events (mail arrived,
// package picked up, ID expiring). HMAC-signed via per-webhook `secret`
// so the receiver can verify authenticity.
//
// Critical privacy rule: a member webhook only ever fires for events
// scoped to that member's userId. The dispatcher in lib/memberWebhooks.ts
// hard-filters on userId match — never broadcasts cross-tenant.
model MemberWebhook {
  id            String   @id @default(cuid())
  userId        String
  label         String                      // "Zapier", "My homelab", "QuickBooks ingest"
  url           String                      // POST target — member-supplied
  secret        String                      // HMAC-SHA256 shared secret (member sees it once on creation)
  events        String                      // JSON array of MemberWebhookEvent keys
  active        Boolean  @default(true)
  failureCount  Int      @default(0)        // consecutive failures since last success — auto-disables at 50
  lastFiredAt   DateTime?
  lastStatus    String?                     // "ok" | "failed:<httpStatus>"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  revokedAt     DateTime?

  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries    MemberWebhookDelivery[]

  @@index([userId, active])
  @@index([revokedAt])
}

// One row per delivery attempt. Same retry shape as iter-134
// WebhookDelivery so we can reuse the cron sweep pattern at /api/cron/
// retry-member-webhooks. Capped per-webhook (most-recent 200 successes
// + every failed/dead-lettered row preserved).
model MemberWebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String
  event        String                       // event key
  payload      String                       // JSON snapshot
  status       String                       // "ok" | "failed"
  httpStatus   Int?
  error        String?
  durationMs   Int?
  attempt      Int      @default(1)
  nextRetryAt  DateTime?
  deadLettered Boolean  @default(false)
  lastTriedAt  DateTime?
  sentAt       DateTime @default(now())

  webhook      MemberWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, sentAt])
  @@index([nextRetryAt])
  @@index([deadLettered, sentAt])
}

// iter-166 — Customer-facing API tokens (Tier 10 #75).
// Power-user members (especially business clients) can mint read-only
// tokens to programmatically pull their own mail history. Tokens are
// shown ONCE on creation; only their SHA-256 hash + first-8 prefix are
// stored, so the full plaintext can never leak from the database.
//
// Scopes are JSON-serialized strings like "mail:read", "packages:read",
// "profile:read" — additive permission set evaluated at request time.
//
// Lookup pattern in middleware: parse `Bearer noho_<prefix><body>` →
// fetch by tokenPrefix (cheap unique index) → constant-time compare
// the SHA-256 of the body against tokenHash → check revokedAt /
// expiresAt → bump lastUsedAt + lastUsedIp.
model ApiToken {
  id            String    @id @default(cuid())
  userId        String
  name          String                              // "Zapier integration" / "QuickBooks sync" — admin-friendly label
  tokenPrefix   String    @unique                   // first 8 plaintext chars used as the lookup key
  tokenHash     String    @unique                   // SHA-256 hex of the FULL plaintext token
  scopesJson    String    @default("[]")            // JSON array of strings: ["mail:read", "packages:read", "profile:read"]
  lastUsedAt    DateTime?
  lastUsedIp    String?
  expiresAt     DateTime?                           // null = never
  revokedAt     DateTime?
  revokedReason String?                             // optional admin/member explanation
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages        ApiTokenUsage[]

  @@index([userId, createdAt])
  @@index([revokedAt])
}

// Per-request usage log so members + admins can audit "did Zapier fire
// last Tuesday at 3am?". Bounded to last N entries via cleanup or
// pagination — every API request writes one row.
model ApiTokenUsage {
  id          String   @id @default(cuid())
  tokenId     String
  endpoint    String                                // "/api/v1/mail"
  method      String                                // "GET" / "POST"
  status      Int                                   // HTTP status code returned
  ip          String?
  userAgent   String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  token       ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, createdAt])
  @@index([createdAt])
}

// iter-193 — Mailbox color-tag system (Tier 13 #102).
//
// Admin defines a small library of named, colored tags ("VIP",
// "Compliance flag", "Translator-needed", "Snowbird-Q4") and assigns
// any combination to suites. Renders as colored dots on every cell of
// the iter-117 occupancy heatmap so triage is one glance instead of
// drilling into each customer record.
//
// Color is hex (e.g. "#E70013") so the UI can use it directly for both
// the tag chip background and the suite-cell dot fill. Description is
// the hover/tooltip explanation of what the tag means in practice.
model MailboxTag {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String                                  // hex e.g. "#E70013"
  description String?                                 // ≤200 chars
  createdAt   DateTime @default(now())
  createdById String?
  updatedAt   DateTime @default(now()) @updatedAt

  assignments MailboxTagAssignment[]

  @@index([name])
}

// iter-196 — Carrier insurance claim assistant (Tier 13 #105).
//
// Tracks an admin-initiated claim against a carrier (USPS/UPS/FedEx/DHL/
// Amazon) for a damaged/lost mail item. The assistant gathers all the
// evidence the carrier portals ask for — declared value (iter-91),
// intake + supplemental photos (iter-135), tracking number (iter-94),
// storage timeline (iter-87) — and pre-fills it as a JSON blob the
// admin pastes into the carrier portal. We can't auto-submit (no
// public claim API for any major carrier), but we can collapse the
// 30-min "find all the evidence" busywork into 2 minutes.
//
// Status lifecycle:
//   Draft → Filed → (Paid | Denied | Closed)
// Filing date is when admin records the carrier's claim # back in our
// system. Paid/Denied capture the carrier's resolution + amount.
model InsuranceClaim {
  id                String    @id @default(cuid())
  mailItemId        String
  userId            String                              // denormalized for fast member-lookup queries
  carrier           String                              // "USPS" | "UPS" | "FedEx" | "DHL" | "Amazon" | "Other"
  claimType         String                              // "damaged" | "lost" | "missing_contents" | "other"
  declaredValueCents Int                                // snapshot from MailItem at claim-start
  claimedAmountCents Int                                // what we're actually claiming (often == declared)
  status            String    @default("Draft")        // "Draft" | "Filed" | "Paid" | "Denied" | "Closed"
  carrierClaimNumber String?                            // returned by carrier portal once admin files
  evidenceJson      String                              // JSON blob: photos[], timeline[], tracking, sender, intakeDate
  prefillJson       String                              // JSON blob: per-carrier form fields admin can paste
  notes             String?                             // free-form admin notes
  filedAt           DateTime?
  filedById         String?
  paidAt            DateTime?
  paidAmountCents   Int?
  deniedAt          DateTime?
  denialReason      String?
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  createdById       String
  updatedAt         DateTime  @default(now()) @updatedAt

  mailItem MailItem @relation(fields: [mailItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mailItemId])
  @@index([status])
  @@index([carrier, status])
  @@index([createdAt])
}

model MailboxTagAssignment {
  id          String   @id @default(cuid())
  userId      String
  tagId       String
  note        String?                                 // optional context per assignment
  createdAt   DateTime @default(now())
  createdById String?

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  MailboxTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])                           // each tag at most once per user
  @@index([userId])
  @@index([tagId])
  @@index([createdAt])
}

  userId            String
  kind              String   // "Scan" | "Invoice" | "Receipt" | "POD" | "Form1583" | "Other"
  title             String
  blobUrl           String
  mimeType          String
  sizeBytes         Int
  sourceMailItemId  String?
  sourceInvoiceId   String?
  sourceDeliveryId  String?
  tags              String?  // JSON array

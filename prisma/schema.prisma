generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  phone            String?
  passwordHash     String   // For OAuth-only users, this is set to an unguessable random hash
  oauthProvider    String?  // "google" | "apple" | null
  image            String?
  role             String   @default("USER") // "USER" | "ADMIN"
  plan             String?  // "Basic" | "Business" | "Premium"
  planTerm         String?  // "3" | "6" | "14"
  suiteNumber      String?  @unique
  status           String   @default("Active") // "Active" | "Expired"
  squareCustomerId String?  @unique // Linked Square customer ID

  // iPostal1-parity fields
  securityDepositCents      Int       @default(5000)
  securityDepositTotalCents Int       @default(5000)
  kycStatus                 String    @default("Pending") // "Pending" | "Submitted" | "Approved" | "Rejected"
  kycForm1583Url            String?
  kycIdImageUrl             String?
  kycReviewedAt             DateTime?
  kycReviewedBy             String?
  kycNotes                  String?
  mailboxStatus             String    @default("Pending") // "Pending" | "Assigned" | "Active" | "Suspended"
  mailboxAssignedAt         DateTime?
  totpSecret                String?
  totpEnabled               Boolean   @default(false)
  // iter-96: JSON array of SHA-256-hashed one-time recovery codes.
  // Generated alongside enrollment; codes are removed from the array
  // as they're consumed.
  totpRecoveryCodes         String?
  walletBalanceCents        Int       @default(0)
  defaultCardId             String?
  notifPrefs                String?
  organizationId            String?
  planDueDate               String?   // e.g. "2025-06-15" — admin-set due date for plan renewal
  tosAcceptedAt             DateTime?
  kycIdImage2Url            String?   // Second ID for CMRA compliance
  idPrimaryExpDate          String?   // e.g. "2027-03-15"
  idSecondaryExpDate        String?   // e.g. "2028-01-01"
  idPrimaryType             String?   // "DL" | "Passport" | "State ID" | "Military" | etc.
  idSecondaryType           String?
  idPrimaryNumber           String?   // license #, passport #, policy #, lease #, etc. — free-form
  idSecondaryNumber         String?
  idPrimaryIssuer           String?   // optional: state / country / issuing authority
  idSecondaryIssuer         String?
  planExpiresAt             DateTime?
  planAutoRenew             Boolean   @default(false)
  // iter-112: Wallet auto-top-up. When walletBalanceCents drops below
  // walletTopUpThresholdCents, the cron creates a CreditRequest for
  // walletTopUpAmountCents and notifies the customer + admin. Both null
  // means feature disabled (default).
  walletTopUpThresholdCents Int?
  walletTopUpAmountCents    Int?
  walletTopUpLastFiredAt    DateTime?  // throttle — don't re-fire within 24h
  // iter-123: Customer's IANA timezone (e.g. "America/New_York", "Europe/London").
  // When set, time-sensitive emails ("delivered today", "expires Friday")
  // render dates in this TZ instead of the bureau's. Null = use bureau TZ.
  timeZone                  String?
  // iter-183: Member-preferred dashboard locale. "en" | "fr" | "ar".
  // When set, takes precedence over the iter-110 cookie on dashboard
  // load so device changes (phone vs laptop) preserve the choice.
  locale                    String?
  // iter-189: KYC trust score 0-100, computed nightly. Surfaces in
  // admin customer drawer as a colored chip + dedicated low-trust
  // panel for compliance triage. JSON flags array snapshots which
  // axes failed at compute time.
  kycTrustScore             Int?
  kycTrustComputedAt        DateTime?
  kycTrustFlagsJson         String?
  // iter-221: opt-in to the bureau-wide shared-junk blocklist. Defaults
  // to true (opt-out, not opt-in) since auto-blocking unwanted mail is
  // a clear member benefit — but member can disable in settings.
  shareJunkLearning         Boolean   @default(true)
  // iter-222: Smart renewal-reminder cadence profile. JSON blob with
  // {leadTimeDays, sampleSize, avgLatency, recomputedAtIso} learned
  // from MailboxRenewal history. Null until the recompute sweep has
  // observed enough renewals to personalize; falls back to fixed 7d
  // baseline matching iter-111.
  renewalCadenceJson        String?
  // iter-223: opt-in to the public referral leaderboard at /leaderboard.
  // Defaults to false (opt-IN since this is public visibility, not a
  // private benefit). When enabled, member's first name + last initial
  // + credited referral count surface publicly; the rest stays private.
  leaderboardOptIn          Boolean   @default(false)
  // iter-224: Preferred carrier for forwarding (iter-129 + rate-shop).
  // One of "USPS" | "UPS" | "FedEx" | "DHL" | "Cheapest" (default).
  // When set, the rate-quote helper picks the lowest-cost quote within
  // that carrier family; falls back to global cheapest when no quote
  // exists for the preferred carrier.
  preferredCarrier          String?
  // iter-232: 1-line custom slogan that prints under the suite # on every
  // intake/pickup thermal receipt + Avery 5160 suite-pin label. Member-
  // editable from settings, admin-editable from the customer panel.
  // ≤80 chars; sanitized to strip control chars + collapse whitespace.
  suitePinSlogan            String?
  // iter-236: Weekly outbound shipment digest opt-in. When true, the
  // Sunday cron sweep emails a recap of every ShippoLabel + iter-212
  // ShipmentReceipt the member sent in the past 7d (with carrier +
  // tracking + receipt links). Off by default — not everyone wants it.
  outboundDigestOptIn       Boolean   @default(false)
  outboundDigestLastSentAt  DateTime?
  // iter-225: Lockbox auto-assign month-pass — when set to a future
  // date, member's incoming packages auto-assign to a free Lockbox
  // (iter-202) instead of holding at counter. PIN sent via iter-84
  // SMS. Subscription billing for the pass is tracked separately.
  lockboxMonthPassUntil     DateTime?

  // Box ownership type — required for CMRA compliance.
  // A company cannot exist as an individual; if Business, an Owner must be on file.
  boxType                   String?   // "Personal" | "Business"
  businessName              String?   // Legal business name (only when boxType=Business)
  businessOwnerName         String?   // Individual personally responsible
  businessOwnerRelation     String?   // "Owner" | "Officer" | "Member" | "Director" | etc.
  businessOwnerPhone        String?

  cardLast4         String?   // Last 4 digits of card on file
  cardBrand         String?   // "Visa" | "Mastercard" | "Amex" | "Discover"
  cardExpiry        String?   // "MM/YY"
  cardholderName    String?
  cardDiscountPct   Int       @default(0)  // % discount applied to this customer (0-100)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mailItems           MailItem[]
  notaryBookings      NotaryBooking[]
  deliveryOrders      DeliveryOrder[]
  shopOrders          ShopOrder[]
  forwardingAddresses ForwardingAddress[]
  payments            Payment[]
  cards               Card[]
  invoices            Invoice[]
  walletTransactions  WalletTransaction[]
  vaultItems          DocumentVaultItem[]
  mailRequests        MailRequest[]
  keyRequests         KeyRequest[]
  shippoLabels        ShippoLabel[]
  labelUploads        LabelUpload[]
  labelOrders         LabelOrder[]
  mailboxRenewals     MailboxRenewal[]
  customerNotes       CustomerNote[]
  notifications       Notification[]
  pickupToken             String?   @unique // short token for QR express pickup; unique because admin scans by token to find user
  referrals               Referral[] @relation("ReferrerReferrals")
  recurringDeliveries     RecurringDelivery[]
  cancellationRequests    CancellationRequest[]
  junkSenders             JunkSender[]
  vacationHold            VacationHold?
  guestPickups            GuestPickupAuth[]
  scheduledForwardings    ScheduledForwarding[]
  sharedAccessGranted     SharedMailboxAccess[] @relation("PrimaryUser")
  sharedAccessReceived    SharedMailboxAccess[] @relation("SharedUser")
  posSales                POSSale[]
  pickupAppointments      PickupAppointment[]
  doorAccessCodes         DoorAccessCode[]      @relation("DoorCodeUser")
  onboardingViews         OnboardingVideoView[] @relation("OnboardingVideoUser")
  cotmAwards              CustomerOfMonthAward[] @relation("CotmUser")
  apiTokens               ApiToken[]            // iter-166
  memberWebhooks          MemberWebhook[]       // iter-167
  cotmMarketingSlots      CotmMarketingSlot[] @relation("CotmMarketingSlotUser") // iter-169
  // iter-175 — Loyalty tier (Tier 11 #84). Computed by the cron sweep.
  // `loyaltyTier` is the snapshot of the most-recent compute; the
  // history is in `LoyaltyTierAssignment` so admin can see promotions
  // over time. Separate cols so dashboards can render the tile without
  // a join.
  loyaltyTier            String?               // "Bronze" | "Silver" | "Gold" | "Platinum"
  loyaltyTierAt          DateTime?             // when this tier was assigned (most-recent promotion)
  loyaltyAssignments     LoyaltyTierAssignment[]
  stripeAchMandates      StripeAchMandate[]    // iter-177
  planDowngradeRequests  PlanDowngradeRequest[] // iter-179
  renewalOffers           RenewalDiscountOffer[] @relation("RenewalOfferUser")
  idExpiryAlerts          IdExpiryAlert[]
  webhookEndpointsCreated WebhookEndpoint[] @relation("WebhookCreatedBy")
  storageFeeDisputes      StorageFeeDispute[] @relation("DisputeFiledBy")
  storageFeeDisputesAdmin StorageFeeDispute[] @relation("DisputeResolvedBy")
  mailerThreads           MailerThread[]
  suiteTransferRequests   SuiteTransferRequest[] @relation("TransferRequestedBy")
  suiteTransfersDecided   SuiteTransferRequest[] @relation("TransferDecidedBy")
  // iter-231: family-transfer requests filed by this user (as primary owner).
  mailboxFamilyTransfers  MailboxFamilyTransfer[]
  // iter-233: address-of-record curated contacts + change-notice runs.
  addressNotificationContacts AddressNotificationContact[]
  addressChangeNoticeRuns     AddressChangeNoticeRun[]
  // iter-235: lobby-playlist song suggestions filed by this user.
  lobbyPlaylistSongs          LobbyPlaylistSong[]
  // Inverse of AgentConversation.owner. Required for Prisma relation
  // validation; AgentConversation defaults to onDelete: Cascade.
  agentConversations      AgentConversation[]
  // iter-193 — admin-assigned colored tags for fast visual triage in the
  // iter-92 occupancy map ("VIP", "Compliance flag", "Translator-needed",
  // "Snowbird-Q4", etc.). Many-to-many through MailboxTagAssignment.
  mailboxTagAssignments   MailboxTagAssignment[]
  // iter-202 — per-tap junk reports for AI-suggested rule promotion.
  junkReports             JunkReport[]
  // iter-206 — member self-serve plan pause (snowbird/traveler holding fee).
  planPauses              PlanPause[]
  // iter-207 — opt-in lobby selfie wall entries (community spotlight).
  lobbyWallEntries        LobbyWallEntry[]
  // iter-209 — opt-in member directory profile (community/social graph).
  neighborProfile         NeighborProfile?
  // iter-211 — door-camera OCR matches resolved to this user.
  doorWalkInOcrMatches    DoorWalkInOcr[]
  // iter-212 — outbound shipment receipts (1×1in QR sticker on every label).
  shipmentReceipts        ShipmentReceipt[]
  // iter-216 — auto-awarded milestone badges (community + retention).
  memberBadges            MemberBadge[]
  // iter-226 — votes cast on the public roadmap.
  roadmapVotes            RoadmapVote[]
}

model SharedMailboxAccess {
  id            String   @id @default(cuid())
  primaryUserId String   // mailbox owner
  sharedUserId  String   // person who gets read access
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  primaryUser User @relation("PrimaryUser", fields: [primaryUserId], references: [id], onDelete: Cascade)
  sharedUser  User @relation("SharedUser", fields: [sharedUserId], references: [id], onDelete: Cascade)
}

model GuestPickupAuth {
  id          String    @id @default(cuid())
  userId      String
  guestName   String
  guestPhone  String?
  guestEmail  String?
  expiresAt   DateTime?
  usedAt      DateTime?
  active      Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// iter-170 — Recurring scheduled forwarding (Tier 11 #79).
// iter-129 shipped a one-time / ad-hoc version. This iter promotes it
// to a true recurring sweep with cron-driven batches, per-shipment
// audit, vacation-mode pause window, and member-visible batch history.
//
// Frequency math + next-run computation moved to lib/scheduledForwarding.ts.
// The cron (`/api/cron/scheduled-forwarding-sweep`) walks rows where
// `enabled = true AND pauseUntil < today AND nextRunDate <= today`,
// batches every eligible MailItem, atomically transitions them to
// Forwarded + creates one ScheduledForwardingBatch row per shipment +
// audit `mail.scheduled_forward_batch` + sends a member email + fires
// the iter-167 `mail.forwarded` webhook.
model ScheduledForwarding {
  id              String   @id @default(cuid())
  userId          String
  addressId       String?  // ForwardingAddress.id (null = default address)
  frequency       String   @default("weekly") // "weekly" | "biweekly" | "monthly"
  nextRunDate     String   // YYYY-MM-DD
  active          Boolean  @default(true)
  lastRunDate     String?
  createdAt       DateTime @default(now())

  // iter-170 additions:
  enabled         Boolean  @default(true)        // separate from `active` — `enabled=false` is a soft pause; `active=false` is a hard cancel
  pauseUntil      String?                         // YYYY-MM-DD — vacation mode; cron skips if today < pauseUntil
  notes           String?                         // member-supplied note rendered in batch emails ("everything to my snowbird condo")
  lastBatchSize   Int?                            // count of items shipped in the most recent batch (snapshot)
  lastBatchAt     DateTime?                       // ISO timestamp of last batch (separate from `lastRunDate` which is YYYY-MM-DD)

  user            User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches         ScheduledForwardingBatch[]    // iter-170

  @@index([enabled, active, nextRunDate])
}

// iter-170 — Per-shipment record. One row per cron sweep that actually
// shipped at least one item. Members see their batch history; admins
// can audit "did Fatma's last batch include her IRS letter?".
model ScheduledForwardingBatch {
  id            String   @id @default(cuid())
  forwardingId  String
  userId        String                          // denormalized for member-side queries
  addressLabel  String                          // snapshot of the destination at batch time
  addressBody   String                          // full address string at batch time
  itemCount     Int                             // how many MailItems shipped
  itemIdsJson   String                          // JSON array of MailItem.ids included
  notes         String?                         // copied from forwarding.notes at run time
  source        String   @default("cron")       // "cron" | "manual" | "test"
  shippedAt     DateTime @default(now())

  forwarding    ScheduledForwarding @relation(fields: [forwardingId], references: [id], onDelete: Cascade)

  @@index([userId, shippedAt])
  @@index([forwardingId, shippedAt])
}

model MailItem {
  id           String   @id @default(cuid())
  userId       String
  from         String
  type         String   // "Letter" | "Package"
  status       String   @default("Received") // "Received" | "Scanned" | "Awaiting Pickup" | "Forwarded" | "Picked Up" | "Held" | "X Requested"
  scanned      Boolean  @default(false)
  scanImageUrl String?
  label        String?
  date         String

  // iPostal1 mail intake fields
  weightOz         Float?
  dimensions       String?
  exteriorImageUrl String?
  assignedAt       DateTime?
  holdUntil        DateTime?
  feeChargedCents  Int?
  recipientName    String?   // Name on the label / who it's addressed to
  recipientPhone   String?   // Optional phone for recipient
  priority         Boolean   @default(false) // member-flagged as priority
  junkBlocked      Boolean   @default(false) // auto-blocked by junk sender rule
  trackingNumber   String?   // package tracking number
  carrier          String?   // "UPS" | "USPS" | "FedEx" | "DHL" | "Amazon"
  // iter-91: Member-declared package value + the insurance fee they
  // paid for it. Free up to $100 declared, then tiered. Both null when
  // customer hasn't declared.
  declaredValueCents Int?
  insuranceFeeCents  Int?
  // iter-93: Public-share token for /p/[id]?t={token} — null until the
  // owner clicks "Share" on the dashboard. Anyone with the link can see
  // the package's photo + status timeline (no other PII).
  publicShareToken   String?  @unique
  // iter-108: AI photo analysis (Claude Vision). JSON blob with detected
  // attributes (fragile, hazmat, leaking, etc.) + raw model output. Null
  // until the post-intake analysis completes (or never set if no API key).
  aiAnalysisJson     String?
  // iter-135: Multi-photo intake gallery. JSON array of
  // `{ id: string, url: string, label?: string, addedAt: string }`. Null
  // when only the primary `exteriorImageUrl` exists. The primary stays
  // separate so AI analysis + thumbnail-list reads keep working as-is;
  // these are the SUPPLEMENTAL angles (back, label close-up, contents,
  // damage). Customer + admin both see the full set as one strip.
  extraPhotosJson    String?
  // iter-137: Pickup signature capture. SVG path-data string (no markup
  // wrapper — the renderer adds the <svg>/<path> at display time so we
  // can reuse for receipts/PDFs/audit pages). Captured when admin marks
  // Picked Up; null until then. Paired with pickupSignerName (typed
  // legal name) and pickupSignedAt (timestamp) for chain-of-custody.
  pickupSignatureSvg String?
  pickupSignerName   String?
  pickupSignedAt     DateTime?
  // iter-194: AI translation of the scanned letter (Claude Vision OCR +
  // translate). JSON blob with shape:
  //   { language, sourceLanguage, originalText, translatedText, model,
  //     promptVersion, translatedAtIso }
  // Member can re-translate to a different language; the latest result
  // overwrites. Null until member clicks "🌐 Translate". Reuses the
  // iter-108 AI pattern (lib helper, fallback when ANTHROPIC_API_KEY
  // unset, audit log on every call).
  translationJson    String?
  // iter-227: AI mail-priority inference (Tier 17 #136).
  // 0-100 attention-priority score computed from (a) iter-218 doc-
  // classifier category, (b) regex hits in OCR'd text, (c) sender
  // pattern, (d) member-side flags (junkBlocked → 0). Recomputed by
  // the iter-227 sweep when scan + classify + translate are all done.
  priorityScore      Int?
  priorityReasonsJson String?     // JSON array of {reason, weight} for explain-ability

  createdAt    DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests MailRequest[]
  storageAlerts StorageThresholdAlert[]
  senderThankYous SenderThankYou[]    // iter-168
  insuranceClaims InsuranceClaim[]   // iter-196
  junkReports     JunkReport[]       // iter-202

  // Hot-path indexes — dashboard reads /admin reads scan by these constantly.
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status])
  @@index([date])
}

model JunkSender {
  id        String   @id @default(cuid())
  userId    String
  sender    String   // sender name/address pattern to block
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// iter-221 — Bureau-wide crowdsourced junk-sender blocklist (Tier 16 #130).
//
// When ≥10 unique members tag the same normalized sender as junk
// (via iter-202 JunkReport or iter-149 JunkSender rule), promote
// it to the bureau-wide blocklist. Members opted in via
// `User.shareJunkLearning=true` benefit from the shared learning
// (iter-202 hook auto-flips junkBlocked on inbound mail). Admin
// can manually add or remove from the panel.
//
// `evidenceCount` snapshots the # of unique reporters at promotion
// time (audit trail). `lastReportedAt` ticks each time a fresh
// report would have triggered if the row didn't already exist.
model BureauJunkSender {
  id                String    @id @default(cuid())
  normalizedSender  String    @unique                       // lowercased + trimmed canonical sender
  displayName       String                                  // most-recent senderRaw — preserves capitalization for UI
  status            String    @default("Active")           // "Active" | "Removed"
  evidenceCount     Int       @default(0)                  // # unique members who reported at promotion time
  source            String    @default("crowdsourced")     // "crowdsourced" | "manual"
  notes             String?
  addedById         String?                                 // admin id when source=manual
  addedAt           DateTime  @default(now())
  lastReportedAt    DateTime?                               // bumped when a new report on this sender lands
  removedAt         DateTime?
  removedById       String?
  removedReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  @@index([status, addedAt])
  @@index([normalizedSender])
}

// iter-226 — Public roadmap voting (Tier 16 #135).
//
// Admin-curated list of upcoming features that members can upvote
// at the public `/roadmap` route. Each member gets one vote per
// item (idempotent via @@unique). Items have a status lifecycle so
// admin can move them through Idea → Planned → InProgress → Shipped.
//
// `position` lets admin manually re-order featured items above the
// vote-count sort; defaults to 0 so vote-count sort applies.
model RoadmapItem {
  id           String    @id @default(cuid())
  title        String                                       // ≤80 chars
  description  String                                       // ≤500 chars
  category     String?                                      // free-form, e.g. "Mobile" / "Billing" / "Notary"
  status       String    @default("Idea")                 // "Idea" | "Planned" | "InProgress" | "Shipped" | "Declined"
  position     Int       @default(0)                       // optional manual ordering (high = top)
  shippedIter  Int?                                         // when status=Shipped, the iter number that delivered it
  createdById  String?                                      // admin who added it
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  votes        RoadmapVote[]

  @@index([status, position])
  @@index([createdAt])
}

model RoadmapVote {
  id           String    @id @default(cuid())
  roadmapItemId String
  userId       String
  createdAt    DateTime  @default(now())

  item RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roadmapItemId, userId])                        // one vote per item per user
  @@index([userId])
  @@index([roadmapItemId])
}

// iter-217 — Smart pickup-bell QR (Tier 16 #126).
//
// Customer scans a single QR sticker on the front-desk bell, enters
// their suite #, and an admin gets a push notification "🛎️ #042 is
// at the counter". Captures who walked in, how many open packages
// they have, when they arrived, when admin acknowledged.
//
// Throttle: rate-limited per IP via a query against `[ip, ringedAt]`
// before insert (no schema-side trigger since Prisma+SQLite). Public-
// facing — no auth — but resolves to userId when the suite # matches
// a User row so admin sees the member's name.
model BellRing {
  id                String    @id @default(cuid())
  suiteNumber       String                                 // typed by walk-in customer
  userId            String?                                // resolved when suite # matches
  ringedAt          DateTime  @default(now())
  ip                String?                                // diagnostic + throttling
  userAgent         String?
  acknowledgedAt    DateTime?
  acknowledgedById  String?
  notes             String?

  @@index([acknowledgedAt, ringedAt])                     // unack queue + recency sort
  @@index([userId, ringedAt])
  @@index([ip, ringedAt])                                  // throttle lookup
}

// iter-216 — Member milestone badges (Tier 15 #125).
//
// Auto-awarded by the daily cron sweep when a member crosses a
// threshold (1y tenure, 100 packages received, $1000 lifetime
// spend, 10 referrals credited, etc). Badges are append-only —
// once awarded, the row stays even if the member's later activity
// dips below the threshold. The `@@unique([userId, badgeKey])`
// constraint makes the sweep idempotent.
//
// Surfaces:
//   - Member dashboard: <MemberBadgesCard>
//   - iter-180 iCal feed: as separate "🏆 1-year member" all-day
//     events on the awarded date
//   - iter-209 NeighborsPanel: badge emoji row next to display name
//   - iter-207 LobbyWallEntry: future overlay
model MemberBadge {
  id             String    @id @default(cuid())
  userId         String
  badgeKey       String                                   // "tenure_1y" | "packages_100" | "spend_1000" | etc
  label          String                                   // "1-year member"
  emoji          String                                   // "🎂"
  color          String                                   // hex for chip background
  description    String                                   // ≤200 chars context
  awardedAt      DateTime  @default(now())
  awardedReason  String?                                  // computed evidence: "Joined 2024-05-09 · 365 days ago"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])                            // idempotent sweep — one of each per member
  @@index([userId, awardedAt])
  @@index([badgeKey])
}

// iter-214 — Bureau alumni network (Tier 15 #123).
//
// When a member finalizes their cancellation, admin can offer them a
// free "alumni" tier: we keep their email + Form 1583 archived for 5
// years (CMRA minimum) + send a quarterly "we miss you" newsletter
// (iter-152 pattern). Pure reactivation funnel — no schema change to
// User, alumni stand on their own row so we don't pollute the active
// member table.
//
// Lifecycle:
//   originalUserId is set when the source is a member cancellation,
//   null when admin manually adds someone (e.g. former owner of a
//   bureau franchise that just acquired NOHO).
//   reactivatedToUserId fires when an alumni signs back up; we mark
//   the alumni row Reactivated + link the new User to track funnel
//   conversion.
//
// Privacy: archived for 5y from alumniSince, then admin can soft-purge
// via `admin.alumni.purged` audited action (not cron-automated — manual
// per-row decision matters legally).
model AlumniMember {
  id                   String    @id @default(cuid())
  originalUserId       String?                                  // set when source=cancellation; nullable when manually added
  email                String                                   // canonical lowercase
  name                 String                                   // snapshot at conversion
  alumniSince          DateTime  @default(now())
  planEndDate          String?                                  // member's last plan due date — for context in newsletter
  kycForm1583Url       String?                                  // snapshot, archived for the 5y CMRA retention window
  source               String    @default("cancellation")      // "cancellation" | "manual" | "import"
  status               String    @default("Active")             // "Active" | "Reactivated" | "Unsubscribed" | "Purged"
  unsubscribeToken     String    @unique                        // public token for one-click unsubscribe link
  reactivatedAt        DateTime?
  reactivatedToUserId  String?                                  // when alumni signs back up
  lastNewsletterAt     DateTime?                                // bumped by the quarterly cron
  newsletterSentCount  Int       @default(0)
  unsubscribedAt       DateTime?
  unsubscribedReason   String?
  notes                String?                                  // admin-typed
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt

  @@unique([email])
  @@index([status, alumniSince])
  @@index([status, lastNewsletterAt])
  @@index([originalUserId])
}

// iter-212 — Postage-stamp QR receipt (Tier 15 #121).
//
// Every paid USPS / UPS / FedEx shipment ships with a 1×1in sticker
// on the box. The sticker has a QR linking to /receipt/{verifyToken}
// — recipient scans it with their phone and lands on a clean page
// confirming "This package came from NOHO Mailbox · sent by {sender}
// from suite #X · on {date}." Builds trust ("this isn't a phishing
// label") + brand recognition, no PII leaked.
//
// Tied to a ShippoLabel (preferred) OR free-form (admin-issued for
// hand-shipped packages). verifyToken is short + URL-safe so it
// QR-encodes compactly even at 1×1in.
model ShipmentReceipt {
  id              String    @id @default(cuid())
  verifyToken     String    @unique                          // 12-char base64url
  shippoLabelId   String?                                    // back-link to iter-shipping label when shipped via Shippo
  userId          String?                                    // sender (null only when admin issues for non-member)
  senderDisplay   String                                     // shown on the receipt page
  recipientDisplay String                                    // shown on the receipt page (blurred to first name + last initial)
  carrier         String?                                    // "USPS" | "UPS" | "FedEx" | "DHL" | etc
  trackingNumber  String?
  shippedFrom     String                                     // bureau name + suite # snapshot
  shippedAt       DateTime  @default(now())                  // when admin printed the label
  scanCount       Int       @default(0)                      // bumped each public scan
  lastScannedAt   DateTime?
  createdAt       DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([shippoLabelId])
}

// iter-211 — Door-camera OCR for walk-ins (Tier 15 #120).
//
// When iter-156 DoorAccessEntry logs an unknown / denied code (or any
// time the camera captures a face the system doesn't recognize), an
// integration uploads the camera frame here. We run iter-108 Claude
// Vision OCR against it to extract any visible card/badge text (e.g.
// the suite # on a printed pickup pass, a member ID, a name on a
// driver's license they're holding) and try to match against User
// rows. Admin reviews the queue, confirms or dismisses.
//
// Status lifecycle:
//   Pending  → admin hasn't looked yet
//   Matched  → admin confirmed `matchedUserId` is who walked in
//   Dismissed → false positive (delivery driver, lost tourist, etc.)
//
// `doorEntryId` optionally links back to the iter-156 DoorAccessEntry
// row that triggered the capture, so admin can see "this was the
// 11:42 AM denied attempt".
model DoorWalkInOcr {
  id                String    @id @default(cuid())
  capturedAt        DateTime  @default(now())
  imageUrl          String                                  // Vercel Blob / external CDN URL of the camera frame
  doorEntryId       String?                                 // iter-156 link, when triggered by a door event
  ocrText           String?                                 // raw text extracted by Vision (≤2000 chars)
  ocrConfidence     Float?                                  // 0..1 model self-rating
  detectedHints     String?                                 // JSON: { suiteNumber?, memberName?, idType?, hasFace? }
  matchedUserId     String?                                 // resolved on confirm
  status            String    @default("Pending")          // "Pending" | "Matched" | "Dismissed"
  reviewedById      String?
  reviewedAt        DateTime?
  notes             String?
  createdAt         DateTime  @default(now())

  matchedUser User? @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)

  @@index([status, capturedAt])
  @@index([matchedUserId])
}

// iter-209 — Mailbox neighbor introductions (Tier 15 #118).
//
// Opt-in member directory. When a member opts in, they get to SEE
// other opted-in members' first name + suite # + bio + photo at
// `/dashboard?tab=neighbors`. Reciprocal — if you're not opted in,
// you can't see the directory and other members can't see you. This
// is the social-graph foundation for community features (cookouts,
// notary buddies, supply trades).
//
// Messaging: members can send each other text-only DMs through the
// `messageNeighbor` server action which fires an email to the target
// via the existing iter-84 sendEmail infrastructure — the target's
// email address is NEVER exposed to the sender's client.
model NeighborProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  displayName     String                                  // member's chosen public name
  bio             String                                  // ≤300 chars
  photoUrl        String?                                 // optional avatar
  status          String    @default("Active")           // "Active" | "Hidden"
  consentedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

// iter-207 — Lobby selfie wall (Tier 15 #116).
//
// Opt-in only. Members upload a photo + (optional) display-name override
// + consent timestamp. Admin reviews + approves; only Approved entries
// appear on the public `/wall` route and in the iter-195 lobby kiosk
// loop. Members can revoke anytime → status flips to Removed and the
// entry stops surfacing immediately.
//
// `joinedYear` snapshots the calendar year the member's mailboxAssignedAt
// or createdAt fell in, used to render the "since 2024" sticker.
model LobbyWallEntry {
  id              String    @id @default(cuid())
  userId          String
  photoUrl        String
  displayName     String                                  // first name OR member-provided override
  suiteNumber     String?                                 // snapshotted at opt-in
  joinedYear      Int                                     // YYYY for the "since" sticker
  consentedAt     DateTime  @default(now())               // when member tapped "I consent"
  status          String    @default("Pending")          // "Pending" | "Approved" | "Removed"
  reviewedById    String?                                 // admin who approved/removed
  reviewedAt      DateTime?
  removedReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
}

// iter-206 — Member self-serve plan pause (Tier 14 #115).
//
// Snowbirds + long-term travelers pay a $5/mo holding fee to keep
// their suite + mail intake while their full subscription is paused.
// When the pause `startDate` hits, the cron sweeper sets status=Active
// and snapshots the member's `plan + planTerm` so we can restore them
// on resume. When `endDate` hits, the sweeper sets status=Resumed and
// puts the original plan back. Member can cancel a Scheduled pause
// (before it starts) or early-resume an Active pause anytime.
//
// Lifecycle:
//   Scheduled → Active → Resumed (auto on endDate or member-initiated early)
//             → Cancelled (member-initiated, only while Scheduled)
model PlanPause {
  id                  String    @id @default(cuid())
  userId              String
  startDate           String                              // YYYY-MM-DD
  endDate             String                              // YYYY-MM-DD (auto-resume target)
  holdingFeeCents     Int                                 // total fee for the pause window (snapshot at request)
  reason              String?                             // free-text member note
  status              String    @default("Scheduled")    // "Scheduled" | "Active" | "Resumed" | "Cancelled"
  originalPlan        String?                             // snapshot of User.plan at request time
  originalPlanTerm    String?                             // snapshot of User.planTerm at request time
  activatedAt         DateTime?
  resumedAt           DateTime?
  resumedEarly        Boolean   @default(false)           // member resumed before endDate
  cancelledAt         DateTime?
  cancelledReason     String?
  createdAt           DateTime  @default(now())
  createdById         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, startDate])
  @@index([status, endDate])
}

// iter-202 — Per-tap junk reports for AI-suggested rule promotion.
// Each time a member taps "Block / Discard junk" on a single mail item
// we drop a row here. When ≥3 reports stack up for the same normalized
// sender (no JunkSender rule yet), the dashboard surfaces a "Auto-
// discard from this sender going forward?" suggestion. Promoting the
// suggestion creates a real JunkSender rule + marks these reports as
// promoted so they stop nudging.
model JunkReport {
  id               String   @id @default(cuid())
  userId           String
  mailItemId       String
  senderRaw        String                                  // original "from" string
  normalizedSender String                                  // lowercased + trimmed for grouping
  createdAt        DateTime @default(now())
  promotedToRule   Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailItem MailItem @relation(fields: [mailItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mailItemId])                           // one report per item per user — re-tapping is idempotent
  @@index([userId, normalizedSender])
  @@index([userId, promotedToRule, createdAt])
}

model VacationHold {
  id        String    @id @default(cuid())
  userId    String    @unique
  startDate String    // "2025-07-01"
  endDate   String    // "2025-07-14"
  digest    Boolean   @default(true) // send daily digest email
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// iter-101 — Pickup-time scheduling.
// Customers book a 15-minute pickup slot from the member dashboard;
// admin sees a sorted queue + can check them in / mark complete / no-show.
// Slots are derived from OperatingHoursConfig (skips break window + holidays).
model PickupAppointment {
  id           String    @id @default(cuid())
  userId       String
  scheduledAt  DateTime  // slot start in UTC
  durationMin  Int       @default(15)
  status       String    @default("Scheduled") // "Scheduled" | "Checked-In" | "Completed" | "Cancelled" | "No-Show"
  packageCount Int?      // member's estimate ("how many packages?")
  guestName    String?   // optional — guest doing the pickup
  notes        String?   // member-provided note
  checkedInAt  DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelledBy  String?   // "user" | "admin"
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, status])
  @@index([userId, scheduledAt])
}

// iter-130 — Holiday-aware email scheduler.
// When a sender (storage-fee warning, plan-renewal reminder, ID expiry,
// vacation-hold confirm, etc.) wants to fire while the bureau is closed
// (per iter-90 operating-hours holidays), it enqueues here instead of
// sending immediately. The hourly drain cron sends them on the next
// business day. Status moves Pending → Sent / Failed / Cancelled.
model DeferredEmail {
  id            String    @id @default(cuid())
  kind          String                       // matches EmailLog.kind
  recipientEmail String
  recipientUserId String?                    // optional User.id
  subject       String
  bodyHtml      String                       // rendered + ready to send as-is
  deferUntilIso DateTime                     // earliest send time (next biz day open)
  status        String    @default("Pending") // "Pending" | "Sent" | "Failed" | "Cancelled"
  reason        String                       // why deferred — e.g. "Closed for Memorial Day"
  attemptCount  Int       @default(0)
  lastError     String?
  enqueuedAt    DateTime  @default(now())
  sentAt        DateTime?

  @@index([status, deferUntilIso])
  @@index([recipientUserId])
}

// iter-122 — Member self-service suite transfer.
// Customer requests a swap to a vacant suite # (e.g. memorable number,
// matches business name). Admin reviews + approves; on approval we
// atomically update User.suiteNumber + audit. Status stays "Pending"
// until decided so member sees a banner; after decision we keep the
// row for the audit trail.
model SuiteTransferRequest {
  id            String    @id @default(cuid())
  userId        String                       // member who filed
  fromSuite     String                       // snapshot of current suite at file time
  toSuite       String                       // requested target
  reason        String                       // member's note
  status        String    @default("Pending") // "Pending" | "Approved" | "Denied" | "Cancelled"
  decidedAt     DateTime?
  decidedById   String?                       // admin who approved/denied
  decisionNote  String?
  createdAt     DateTime  @default(now())

  user      User  @relation("TransferRequestedBy", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("TransferDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt])
}

// iter-118 — Apple-Mail-style mailer with inbox + replies + notices.
//
// MailerThread groups outbound + inbound messages between the bureau
// and one customer email. Replies (inbound) get ingested via the
// `/api/email/inbound` webhook (Resend / SendGrid / Postmark all
// support a similar POST shape). Outbound reply or notice sends create
// new MailerMessage rows tagged direction="out" + write to EmailLog
// for delivery audit.
model MailerThread {
  id              String          @id @default(cuid())
  customerEmail   String                          // canonical lowercase email
  customerUserId  String?                         // resolved User.id when we know them
  subject         String                          // most recent subject line, used as thread title
  lastMessageAt   DateTime        @default(now())
  unreadCount     Int             @default(0)     // count of inbound messages not yet read
  archived        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customerUser    User?           @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  messages        MailerMessage[]

  @@index([customerEmail])
  @@index([archived, lastMessageAt])
  @@index([customerUserId])
}

model MailerMessage {
  id          String   @id @default(cuid())
  threadId    String
  direction   String                       // "in" | "out"
  fromEmail   String
  toEmail     String
  subject     String
  bodyHtml    String                       // sanitized HTML or plain wrapped
  bodyText    String?                      // optional plaintext fallback
  providerId  String?                      // Resend / SMTP message-id for outbound; webhook id for inbound
  unread      Boolean  @default(true)
  templateId  String?                      // when admin sent from a notice template
  bulkBatchId String?                      // when part of a bulk notice (groups outbound rows)
  // iter-141: when set, this outbound row was sent by a MailerAutoReplyRule.
  // Lets the panel render an auto-reply badge + lets the engine skip
  // re-triggering on its own outbound messages.
  autoReplyRuleId String?
  sentAt      DateTime @default(now())

  thread MailerThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, sentAt])
  @@index([bulkBatchId])
}

// iter-141 — Mailer auto-reply rules (Tier 8 #53).
// Admin defines keyword triggers (case-insensitive contains). When an
// inbound email matches an active rule, the rule's reply template
// auto-fires once per thread per cooldown window. The cooldown prevents
// reply-loops with mis-configured external systems. Templates support
// `{customerName}`, `{originalSubject}`, `{firstLine}` placeholders.
model MailerAutoReplyRule {
  id              String   @id @default(cuid())
  label           String                   // admin's label for the rule (e.g. "After-hours auto-reply")
  matchOn         String   @default("any") // "any" | "subject" | "body"
  keywords        String                   // JSON array of strings, case-insensitive contains
  replySubject    String                   // template
  replyBodyHtml   String                   // template (allowed simple HTML)
  active          Boolean  @default(true)
  cooldownHours   Int      @default(24)    // skip if this rule already fired for the same customer within this window
  businessHours   String   @default("any") // "any" | "open" | "closed"
  sendCount       Int      @default(0)     // number of times the rule has actually fired
  lastFiredAt     DateTime?
  createdBy       String?                  // admin user id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
}

// iter-105 — Storage-fee dispute workflow.
// Customer files a dispute against an applied storage fee (set in
// MailItem.feeChargedCents by iter-87). Admin reviews and either waives
// (refund to wallet) or upholds (no change). One open dispute per
// MailItem at a time — enforced via @@unique on (mailItemId, status="Open").
// We model "Open" via a partial constraint trick: store status NULL when
// resolved so the unique index slot frees up. SQLite supports this.
model StorageFeeDispute {
  id            String    @id @default(cuid())
  mailItemId    String                       // disputed item
  filedById     String                       // member who filed
  feeCents      Int                          // snapshot of fee at file time
  reason        String                       // member's explanation
  status        String    @default("Open")   // "Open" | "Waived" | "Upheld"
  resolution    String?                      // admin note on close
  resolvedAt    DateTime?
  resolvedById  String?                      // admin who resolved
  refundCents   Int?                         // amount refunded if Waived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  filedBy    User @relation("DisputeFiledBy", fields: [filedById], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("DisputeResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  messages   DisputeMessage[]                // iter-186

  @@index([mailItemId])
  @@index([status, createdAt])
  @@index([filedById, createdAt])
}

// iter-186 — Member ↔ admin chat thread on a billing dispute (Tier 12 #95).
// Lets both sides negotiate before resolution. Each post knows its
// author + role + read receipts on each side so we can show "1 unread"
// badges + admin can prioritize threads with new member messages.
model DisputeMessage {
  id              String    @id @default(cuid())
  disputeId       String
  authorId        String                            // user.id of the poster
  authorRole      String                            // "MEMBER" | "ADMIN"
  body            String                            // 1-2000 chars
  readByMemberAt  DateTime?
  readByAdminAt   DateTime?
  createdAt       DateTime  @default(now())

  dispute         StorageFeeDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId, createdAt])
  @@index([authorId, createdAt])
}

// iter-103 — Slack/Discord/generic webhook bridge.
// Admin-configured outbound webhooks fire on operational events (package
// arrived, pickup completed, dropoff logged, appointment booked). Each
// endpoint has a per-event filter so a Slack channel can subscribe to
// only "package arrived" while a Discord ops channel gets everything.
// `format` lets us emit Slack-flavored, Discord-flavored, or generic JSON
// without a separate model per provider.
model WebhookEndpoint {
  id          String   @id @default(cuid())
  label       String                    // human label, e.g. "Front desk Slack"
  url         String                    // POST target
  format      String   @default("slack") // "slack" | "discord" | "generic"
  events      String                    // JSON array of event keys, e.g. ["mail.arrived","mail.picked_up"]
  active      Boolean  @default(true)
  secret      String?                   // optional shared secret, sent in X-NOHO-Signature header (HMAC-SHA256)
  createdBy   String?                   // admin User.id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastFiredAt DateTime?
  lastStatus  String?                   // "ok" | "failed:<status>"

  creator    User?               @relation("WebhookCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([active])
}

// One row per delivery attempt so admin can see what fired, when, and
// any HTTP error returned. Capped — only last ~200 retained per endpoint
// (we trim on insert to keep storage bounded).
model WebhookDelivery {
  id         String   @id @default(cuid())
  endpointId String
  event      String                     // event key
  payload    String                     // JSON snapshot of what was sent
  status     String                     // "ok" | "failed"
  httpStatus Int?
  error      String?
  durationMs Int?
  sentAt     DateTime @default(now())

  // iter-134 — Retry & dead-letter queue.
  // attempt counts attempts that have already executed (1 = first try).
  // nextRetryAt is non-null while a retry is queued; null after success
  // or once dead-lettered. deadLettered flips true after MAX_ATTEMPTS so
  // the cron stops touching it but admin can still see + replay it.
  // lastTriedAt tracks the most recent attempt (sentAt is the FIRST try
  // for stable ordering; we don't want retries to jump rows around).
  attempt       Int      @default(1)
  nextRetryAt   DateTime?
  deadLettered  Boolean  @default(false)
  lastTriedAt   DateTime?

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, sentAt])
  @@index([nextRetryAt])
  @@index([deadLettered, sentAt])
}

// iter-159 — Weekly bureau newsletter (Tier 10 #69).
// One row per ISO-week per send. weekKey is "YYYY-WNN" (e.g. "2026-W19")
// and is unique so the cron can't double-send. recipientCount + cohort
// counts are kept for retention analytics. Editorial is the admin's
// optional intro paragraph layered on top of the auto-compiled recap.
model NewsletterIssue {
  id              String   @id @default(cuid())
  weekKey         String   @unique
  weekStart       DateTime
  weekEnd         DateTime
  subject         String
  editorial       String?                          // admin-written intro
  bodyHtml        String                           // rendered HTML at send time (snapshot)
  recipientCount  Int      @default(0)
  failedCount     Int      @default(0)
  sentAt          DateTime @default(now())
  sentById        String?

  @@index([sentAt])
}

// iter-153 — Renewal-discount auto-offer (Tier 9 #63).
// Cron sweep finds at-risk customers (per iter-140 health score) whose
// renewal is in the next 30 days and sends them a one-time discount
// code. One non-redeemed offer per user at a time; the cron checks for
// an existing active offer before creating a new one.
model RenewalDiscountOffer {
  id           String    @id @default(cuid())
  userId       String
  code         String    @unique          // generated NOHO-DDDDDD format
  percentOff   Int                          // 0-100
  expiresAt    DateTime                     // hard expiration
  sentAt       DateTime  @default(now())
  redeemedAt   DateTime?                    // null until member redeems
  redeemedById String?                      // resolves to userId — kept separate for audit
  reason       String?                      // why the offer was generated (e.g. "health=Watch, dueIn=14d")
  createdAt    DateTime  @default(now())

  user User @relation("RenewalOfferUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, redeemedAt])
  @@index([expiresAt])
}

// iter-152 — Customer-of-the-month award (Tier 9 #62).
// Admin nominates one customer per (year, month). Composite unique
// constraint enforces "exactly one winner per month" in the DB so a
// race can never produce duplicates. Once awarded, the member sees a
// badge + citation on their dashboard + gets a congrats email.
model CustomerOfMonthAward {
  id           String   @id @default(cuid())
  userId       String
  year         Int
  month        Int                              // 1-12
  citation     String                           // why they won (admin-written, public to that customer)
  awardedById  String?
  awardedAt    DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation("CotmUser", fields: [userId], references: [id], onDelete: Cascade)
  marketingSlot CotmMarketingSlot?              // iter-169 — opt-in spotlight

  @@unique([year, month])                       // one winner per month
  @@index([userId, awardedAt])
}

// iter-150 — Supplies inventory management (Tier 9 #60).
// Internal-ops inventory of consumables: boxes, tape, labels, poly
// mailers, envelopes, printer ribbons. Distinct from CatalogItem
// (which is the Square-synced retail catalog visible to customers).
// Stock movement is kept as a separate event log so admin can audit
// "where did 50 small boxes go between Monday and Wednesday".
model Supply {
  id              String   @id @default(cuid())
  name            String
  category        String                              // "boxes" | "tape" | "labels" | "poly_mailers" | "envelopes" | "printer_ribbon" | "other"
  unit            String   @default("each")           // "each" | "roll" | "box" | "case" | "ream"
  onHand          Int      @default(0)
  reorderAt       Int      @default(5)                // alert when onHand drops below this
  reorderQty      Int      @default(20)               // suggested reorder quantity
  vendor          String?
  vendorSku       String?
  costCents       Int?                                // per-unit cost in cents (optional)
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movements       SupplyMovement[]
  priceTiers      SupplyPriceTier[]                   // iter-164

  @@index([category, isActive])
  @@index([isActive, onHand])
}

// iter-164 — Per-supply pricing tiers (Tier 10 #74).
// Each Supply can have N price tiers (e.g. "Retail", "Member", "Wholesale").
// Exactly one tier per supply is marked `isDefault`; that's the price
// that auto-fills when admin records a `sale` movement. The implicit
// margin is `(salePriceCents - Supply.costCents) / Supply.costCents`.
//
// Margin reports (last N days) join SupplyMovement.kind="sale" against
// the unitPriceCents captured at sale time so historical numbers stay
// stable when the catalog price changes.
model SupplyPriceTier {
  id             String   @id @default(cuid())
  supplyId       String
  label          String                                // "Retail" | "Member" | "Wholesale" | custom
  salePriceCents Int                                   // sale price for this tier (cents)
  isDefault      Boolean  @default(false)              // exactly one default per Supply
  position       Int      @default(0)                  // display order in the panel
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supply         Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@unique([supplyId, label])                          // can't have two "Retail" tiers on the same supply
  @@index([supplyId, position])
  @@index([supplyId, isDefault])
}

// One row per stock change. Delta is signed: positive for restocks +
// returns, negative for sales + losses + intake-consumption.
//
// iter-164 — sale rows now also capture the unit price + tier label at
// the time the sale was rung up. Letting the catalog price drift later
// won't rewrite history. `unitPriceCents` is null for non-sale rows.
model SupplyMovement {
  id              String   @id @default(cuid())
  supplyId        String
  kind            String                              // "restock" | "sale" | "internal_use" | "loss" | "adjust"
  delta           Int                                 // signed
  notes           String?
  performedById   String?
  performedAt     DateTime @default(now())
  unitPriceCents  Int?                                // iter-164 — captured per-unit price for sales
  unitCostCents   Int?                                // iter-164 — Supply.costCents at time of sale (margin denom snapshot)
  tierLabel       String?                             // iter-164 — which SupplyPriceTier was applied
  customerId      String?                             // iter-164 — optional buyer (member sales)

  supply Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@index([supplyId, performedAt])
  @@index([kind, performedAt])
}

// iter-148 — Customer onboarding video walkthrough (Tier 9 #58).
// Admin-curated playlist of short videos new members watch in their
// first week. Each video tracks per-user max-percent-watched (we
// upsert `max(existing, new)` so seeking backward doesn't decrement).
// `OnboardingTouch` records each automated welcome-email touch for
// idempotency (Day 0 / Day 2 / Day 5).
model OnboardingVideo {
  id           String   @id @default(cuid())
  slug         String   @unique             // url-safe key, used by recordVideoView
  title        String
  description  String?
  videoUrl     String                         // hosted file (Vercel Blob, YouTube embed, Vimeo)
  posterUrl    String?                        // optional poster image
  durationSec  Int      @default(0)           // for progress math
  sortIndex    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  views OnboardingVideoView[]

  @@index([isActive, sortIndex])
}

model OnboardingVideoView {
  id              String   @id @default(cuid())
  userId          String
  videoId         String
  percentWatched  Int      @default(0)        // 0-100, monotonically increasing
  firstViewedAt   DateTime @default(now())
  lastViewedAt    DateTime @default(now())
  completedAt     DateTime?                    // set when percentWatched >= 95

  user  User             @relation("OnboardingVideoUser", fields: [userId], references: [id], onDelete: Cascade)
  video OnboardingVideo  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, completedAt])
  @@index([videoId, completedAt])
}

// One row per (userId, touchKey) — written when the cron sends a
// scheduled welcome touch so the next sweep doesn't re-send.
model OnboardingTouch {
  id        String   @id @default(cuid())
  userId    String
  touchKey  String   // "welcome_day0" | "videos_day2" | "checkin_day5"
  sentAt    DateTime @default(now())

  @@unique([userId, touchKey])
  @@index([sentAt])
}

// iter-188 — Smart re-shelving suggestions (Tier 13 #97).
// Daily cron analyzes mail volume × suite assignment × plan tier and
// surfaces actionable nudges: "release dormant suite X to waitlist",
// "Karim is overflowing — upsell him to Business plan", "small box →
// big member" mismatches. Each suggestion can be snoozed 30 days,
// dismissed permanently, or marked as acted-on (links to follow-up).
model ReShelvingSuggestion {
  id             String    @id @default(cuid())
  kind           String                              // "dormant_suite" | "overflow_member" | "size_mismatch" | "vacant_box_for_waitlist"
  severity       String    @default("medium")        // "low" | "medium" | "high"
  suiteNumber    String?                             // when applies to a specific suite
  userId         String?                             // when applies to a specific member
  reasonsJson    String                              // JSON array of {label, value} pairs admin sees
  suggestedAction String                             // one-line plain-English suggestion
  snoozedUntil   DateTime?                           // member-set hide window
  dismissedAt    DateTime?
  dismissedBy    String?
  actedAt        DateTime?
  actedBy        String?
  actedNote      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([kind, suiteNumber, userId])              // one open suggestion per kind+target — re-running cron updates
  @@index([dismissedAt, snoozedUntil, createdAt])
  @@index([severity, createdAt])
}

// iter-187 — Public proof-of-mailing certificate (Tier 13 #96).
// Issued at intake (admin-driven OR auto on iter-83 scan). The
// certificate documents that NOHO received a piece of mail from
// sender X on date Y, addressed to member Z's suite — a printable
// chain-of-custody artifact members can show in court / disputes /
// HR / IRS. Each cert has a public verify URL keyed off
// `verifyToken` so anyone (lawyer, judge, agency) can prove
// authenticity at /cert/<token>. The verify page renders the same
// data + a "verified by NOHO Mailbox" sigil so the recipient can
// trust what the member showed them.
model MailingCertificate {
  id                  String    @id @default(cuid())
  mailItemId          String                            // the MailItem being certified
  certificateNumber   String    @unique                 // human-readable "NMC-2026-00001234"
  verifyToken         String    @unique                 // 16-char public URL token (rotatable)
  // Immutable snapshots — even if the source MailItem is later edited
  // or deleted, the certificate stays correct. Court evidence rules
  // require this.
  recipientName       String
  recipientSuite      String?
  senderName          String
  itemType            String                            // "Letter" | "Package" | etc — copied from MailItem.type
  itemDate            String                            // YYYY-MM-DD intake date
  trackingNumber      String?
  carrier             String?
  weightOz            Int?
  exteriorImageUrl    String?
  notes               String?                           // optional admin note ("hand-delivered + ID verified")
  issuedById          String?                           // admin user id
  revokedAt           DateTime?
  revokedReason       String?
  createdAt           DateTime  @default(now())

  @@index([mailItemId])
  @@index([verifyToken])
  @@index([createdAt])
}

// iter-184 — Carrier label rate shopping (Tier 12 #93).
// Admin types destination zip + weight → we quote USPS / UPS / FedEx /
// DHL side-by-side and stash the snapshot here so future audits can
// see "we picked UPS Ground at $9.40 over USPS Priority at $12.10 on
// May 8". Heuristic engine for now (zone × weight), upgradable to
// real carrier APIs in a future iter without UI/schema churn.
model RateQuote {
  id              String   @id @default(cuid())
  originZip       String                              // bureau origin (defaults to 91601 NoHo)
  destZip         String                              // 5-digit US zip
  weightOz        Int                                 // total weight
  dimensions      String?                             // "12x9x4" optional
  declaredValueCents Int?                             // optional insurance basis
  ratesJson       String                              // JSON: [{carrier, service, etaDays, totalCents, hasInsurance, ...}, …]
  selectedCarrier String?                             // "USPS" | "UPS" | "FedEx" | "DHL"
  selectedService String?                             // service-class snapshot
  selectedTotalCents Int?
  mailItemId      String?                             // optional link to a MailItem we're shipping
  createdById     String?                             // admin user id
  createdAt       DateTime @default(now())

  @@index([destZip, createdAt])
  @@index([createdById, createdAt])
  @@index([mailItemId])
}

// iter-182 — Per-mailbox sticky pin notes (Tier 12 #91).
// Different from iter-120 PinnedNotes (which is per-customer): this
// is per-SUITE — surfaces on every intake + pickup workflow that
// touches that suite #, so staff see "Box 042: hold rent check for
// K. on Tues" the moment they scan a package addressed to suite 042.
// Auto-expire optional (use for time-bounded notes); manual dismiss
// removes from active list but keeps row for audit.
model SuitePinNote {
  id            String    @id @default(cuid())
  suiteNumber   String                              // suite # this pin applies to
  body          String                              // ≤500 chars; admin-typed
  color         String    @default("amber")         // "amber" | "red" | "blue" | "green" — visual urgency
  expiresAt     DateTime?                           // optional auto-expire
  dismissedAt   DateTime?                           // manual dismiss
  dismissedById String?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([suiteNumber, dismissedAt])
  @@index([expiresAt])
}

// iter-181 — Drop-in mailbox tour booking (Tier 12 #90).
// Public marketing-site form lets prospects request a 15-min
// walkthrough of the bureau before signing up. Admin reviews the
// queue, confirms (sends prospect an email), or marks as
// completed/no-show after the visit. `becameMember` flips on the row
// when a confirmed tour converts to a real account so we can compute
// tour→signup conversion rate later.
model MailboxTour {
  id             String    @id @default(cuid())
  name           String                              // prospect's name
  email          String
  phone          String?
  requestedDate  String                              // YYYY-MM-DD
  requestedTime  String                              // "HH:MM" 24-hour preferred slot
  partySize      Int       @default(1)               // # of people coming
  reason         String?                             // free-text "what brought you in"
  status         String    @default("Pending")       // "Pending" | "Confirmed" | "Completed" | "No Show" | "Cancelled"
  source         String    @default("web")           // "web" | "phone" | "walkin"
  ip             String?                             // diagnostic-only — used for rate-limit
  userAgent      String?
  confirmedAt    DateTime?
  confirmedById  String?
  completedAt    DateTime?
  completedById  String?
  becameMember   Boolean   @default(false)           // admin flips when prospect signs up
  becameUserId   String?                             // resolved User.id when becameMember=true
  noShowAt       DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  adminNotes     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, requestedDate])
  @@index([requestedDate, requestedTime])
  @@index([email])
}

// iter-179 — Customer self-serve plan downgrade (Tier 12 #88).
// Counterpart to iter-116's prorate-on-upgrade. Downgrade DOESN'T
// prorate (we don't refund — that opens a customer-service nightmare),
// instead the new lower price applies starting at the next renewal.
//
// Status machine:
//   pending  → member just requested
//   approved → admin reviewed (or auto-approval cron)
//   applied  → cron flipped User.plan on the renewal date
//   cancelled → member changed their mind before applied
//   denied   → admin rejected with a reason (member sees it)
model PlanDowngradeRequest {
  id            String    @id @default(cuid())
  userId        String
  fromPlan      String                            // current plan at request time
  toPlan        String                            // requested target
  effectiveAt   String                            // YYYY-MM-DD when it should apply (= current planDueDate snapshot)
  reason        String?                           // optional member-supplied reason
  status        String    @default("pending")     // "pending" | "approved" | "applied" | "cancelled" | "denied"
  appliedAt     DateTime?
  cancelledAt   DateTime?
  cancelledBy   String?                           // "member" | userId
  deniedAt      DateTime?
  deniedReason  String?
  approvedAt    DateTime?
  approvedById  String?                           // admin who approved
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, effectiveAt])
}

// iter-177 — Stripe ACH renewal payments (Tier 12 #86).
// ACH bank-debit option alongside the iter-89 Square card-only path.
// Materially lower fees on big-ticket Business renewals (0.8% capped
// at $5 vs Square's 2.9% + $0.30).
//
// Two-step flow: (1) member or admin sets up a SetupIntent → Stripe
// hosted bank-link page returns mandateId + bank metadata → we store
// `StripeAchMandate`. (2) For each renewal, admin (or future cron)
// calls `chargeStripeAch(mandateId, amount)` → records
// `StripeAchPayment` row.
//
// Secrets: STRIPE_SECRET_KEY env var. Lib gracefully no-ops when the
// key isn't set so non-Stripe environments still build/run.
model StripeAchMandate {
  id                  String   @id @default(cuid())
  userId              String
  stripeCustomerId    String                              // cus_*
  stripePaymentMethod String                              // pm_*
  stripeMandateId     String?                             // mandate_* — set after first successful charge
  bankName            String?                             // "Wells Fargo"
  bankLast4           String?                             // "4567"
  status              String   @default("pending")        // "pending" | "active" | "revoked" | "failed"
  setupCompletedAt    DateTime?
  revokedAt           DateTime?
  revokedReason       String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments            StripeAchPayment[]

  @@index([userId, status])
  @@index([status, createdAt])
}

// One row per ACH charge attempt. Stripe ACH settles in 4-5 business
// days, so `status` may stay "pending" for a while before flipping
// "succeeded" or "failed" via webhook.
model StripeAchPayment {
  id                       String   @id @default(cuid())
  mandateId                String
  userId                   String
  amountCents              Int
  description              String
  stripePaymentIntentId    String?  @unique
  stripeChargeId           String?
  status                   String   @default("processing") // "processing" | "succeeded" | "failed" | "cancelled"
  failureCode              String?
  failureMessage           String?
  initiatedById            String?                          // admin who fired the charge (null for cron)
  settledAt                DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  mandate                  StripeAchMandate @relation(fields: [mandateId], references: [id], onDelete: Cascade)

  @@index([mandateId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// iter-176 — In-person dropoff barcode kiosk (Tier 11 #85).
// Members generate a printable 12-char Code 128 barcode at home (or
// at the kiosk in the bureau lobby) BEFORE arriving with a package.
// At the front desk, admin scans the barcode and the intake form
// auto-fills the customer + sender + tracking. Cuts ~60s off every
// dropoff intake.
//
// `code` is 12 alphanumeric chars (uppercase, no ambiguous 0/O/1/I) —
// short enough for a 4×6 receipt to print at large size, unique enough
// for thousands of codes per year. claimedAt freezes the row when
// admin scans + intakes; we keep claimed rows for audit.
model DropoffBarcode {
  id                String    @id @default(cuid())
  code              String    @unique                 // 12-char human-typeable, scannable as Code 128
  userId            String?                            // resolved when the code generator was logged in
  suiteNumber       String                             // member typed
  expectedSender    String                             // who's the package from
  expectedTracking  String?                            // optional carrier tracking #
  expectedCarrier   String?                            // "USPS" | "UPS" | "FedEx" | "DHL" | etc
  photoUrl          String?                            // optional Vercel Blob preview the member uploaded
  notes             String?                            // free-form member note
  expiresAt         DateTime                           // codes auto-expire 14 days after generation
  claimedAt         DateTime?                          // when admin scanned + intake completed
  claimedById       String?                            // admin user id
  claimedMailItemId String?                            // resulting MailItem.id
  createdAt         DateTime  @default(now())

  @@index([code])
  @@index([userId, createdAt])
  @@index([claimedAt])
  @@index([expiresAt])
}

// iter-175 — Member loyalty tier history (Tier 11 #84).
// One row per tier transition (promote / demote / re-affirm). Cron
// computes from tenure × payment punctuality × upsells (iter-153
// health score axes), writes to User.loyaltyTier + appends here.
// `reasonsJson` snapshots the qualifying axes so a future audit can
// see "Sami got Gold in May 2026 because tenure=14mo + 12 on-time +
// Premium plan + active autopay".
model LoyaltyTierAssignment {
  id          String   @id @default(cuid())
  userId      String
  tier        String                              // "Bronze" | "Silver" | "Gold" | "Platinum"
  previousTier String?                            // null on first assignment
  reasonsJson String                              // JSON array of {key, label, met:true/false}
  scoreSnapshot Int?                              // health score at time of assignment
  triggeredBy String   @default("system")         // "system" | "admin" | "manual"
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tier, createdAt])
}

// iter-173 — Carrier-pickup scheduling (Tier 11 #82).
// Admin creates a pickup request for USPS/UPS/FedEx/DHL via this
// table. The actual upstream API call (USPS PUL, UPS pickup request,
// FedEx pickup) is admin-driven outside the app for now — admin enters
// the confirmation # returned by the carrier portal once. We track the
// pickup window, package counts, and a status state-machine so a
// no-show cron can flag missed pickups + alert admin.
//
// Status machine:
//   draft → scheduled (admin entered confirmation #)
//          ↘
//           cancelled
//   scheduled → completed (carrier showed up, packages handed off)
//   scheduled → missed (cron auto-marked after the pickup window
//                       closed with no completion stamp)
model CarrierPickup {
  id                  String    @id @default(cuid())
  carrier             String                              // "USPS" | "UPS" | "FedEx" | "DHL" | "Other"
  pickupDate          String                              // YYYY-MM-DD
  pickupWindowOpen    String                              // "HH:MM" 24-hour
  pickupWindowClose   String                              // "HH:MM" 24-hour
  packageCount        Int       @default(0)
  totalWeightOz       Int?                                // total weight (snapshot)
  locationNote        String?                             // "Front desk" / "Back loading dock"
  instructions        String?                             // free-form for the driver
  confirmationNumber  String?                             // returned by the carrier portal once admin schedules it
  status              String    @default("draft")         // "draft" | "scheduled" | "completed" | "missed" | "cancelled"
  scheduledById       String?                             // admin who scheduled it
  scheduledAt         DateTime?                           // when status flipped to scheduled
  completedAt         DateTime?
  completedActualCount Int?                               // packages actually picked up (might differ from estimate)
  cancelledAt         DateTime?
  cancelReason        String?
  missedAt            DateTime?                           // cron-set when no completion past window+grace
  driverName          String?                             // optional, captured at completion
  notes               String?                             // free-form admin note
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status, pickupDate])
  @@index([carrier, pickupDate])
  @@index([pickupDate])
}

// iter-172 — ESP audience sync (Tier 11 #81).
// One-click sync of opted-in members to a configured email service
// provider (Mailchimp, ConvertKit, Buttondown) — or a CSV download for
// any provider not natively supported. Honors per-member newsletter
// opt-in (notifPrefs.marketing.email).
//
// Secrets: provider API keys are stored plaintext in `apiKey`. We rely
// on Turso/libsql at-rest encryption + admin-only access to this
// model. A future iter could move secrets to env-only references.
model EspAudienceSync {
  id              String    @id @default(cuid())
  provider        String                              // "mailchimp" | "convertkit" | "buttondown" | "csv"
  label           String                              // human-readable (e.g. "Main marketing list")
  audienceId      String?                             // Mailchimp list ID, ConvertKit form ID, etc — null for CSV
  apiKey          String?                             // provider API key — null for CSV
  apiServer       String?                             // Mailchimp data center suffix (e.g. "us21")
  isActive        Boolean   @default(true)
  marketingOptInOnly Boolean @default(true)           // when true, only members with notifPrefs.marketing.email = true
  doubleOptIn     Boolean   @default(false)           // pass through to providers that support it

  lastSyncAt      DateTime?
  lastSyncCount   Int?                                // number of contacts pushed in the last successful sync
  lastSyncFailed  Int?                                // number that failed
  lastSyncError   String?
  lastSyncBy      String?                             // admin user id

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  syncs           EspSyncRun[]

  @@index([isActive])
}

// One row per sync run. Captures the count + sample of who got pushed
// + the per-provider response so admin can audit "did we accidentally
// add a cancelled customer to our newsletter list yesterday?".
model EspSyncRun {
  id            String   @id @default(cuid())
  audienceId    String                                // FK to EspAudienceSync.id
  source        String   @default("manual")           // "manual" | "scheduled" | "test"
  total         Int                                   // resolved candidate count
  added         Int                                   // contacts pushed successfully
  skipped       Int                                   // already-on-list / no-email / opt-out
  failed        Int                                   // provider returned error
  error         String?                               // first error if any
  durationMs    Int?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  startedBy     String?                               // admin user id

  audience      EspAudienceSync @relation(fields: [audienceId], references: [id], onDelete: Cascade)

  @@index([audienceId, startedAt])
}

// iter-171 — Lockbox keypad live status board (Tier 11 #80).
// Physical lockbox in the storefront. One row per box; a `state` flips
// to `open` when admin (or future hardware) records an unlock, then
// back to `closed` after the door is shut. The admin tablet board
// polls `getLockboxBoard()` every 5s and renders a live grid:
// who opened which box, when, and for how long. After-hours opens past
// `expectedCloseBy` light up red and fire an admin webhook.
model Lockbox {
  id                 String    @id @default(cuid())
  label              String    @unique         // "Box 14" — short, fits on the keypad sticker
  location           String?                   // "Front room east wall, top row"
  serial             String?                   // physical serial / model
  isActive           Boolean   @default(true)
  // iter-225: opt this lockbox into the auto-assign rotation. Some
  // bureaus reserve a few boxes for VIPs / oversized only — toggle
  // those off here so the auto-assigner skips them.
  autoAssignEnabled  Boolean   @default(true)
  state              String    @default("closed") // "closed" | "open" | "ajar" | "fault"
  openedAt           DateTime?                 // when the most-recent open event fired
  openedByUserId     String?                   // resolved member id, when known
  openedByEntryId    String?                   // DoorAccessEntry.id that triggered the open
  openedReason       String?                   // "pickup" | "drop_off" | "admin_manual" | "service" — free-form
  expectedCloseBy    DateTime?                 // when we expect the door shut — overdue past this
  lastClosedAt       DateTime?                 // when the door most-recently shut
  notes              String?                   // free-form admin note

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  events             LockboxEvent[]

  @@index([state, isActive])
  @@index([openedAt])
}

// iter-225 — Lockbox auto-assign records (Tier 16 #134).
//
// One row per auto-assignment. When a MailItem arrives + the member
// has a current month-pass + an opted-in Lockbox is free, the cron
// claims the box, generates a 6-digit pickup PIN, fires an SMS, and
// drops the row here. status walks Open → PickedUp (member opens with
// PIN) → Released (admin closes after pickup) → Expired (PIN unused
// past expiresAt).
model LockboxAssignment {
  id                String    @id @default(cuid())
  lockboxId         String                                // FK to Lockbox
  mailItemId        String                                @unique  // one assignment per package
  userId            String                                // denormalized for quick member-lookup
  pickupPin         String                                // 6-digit, stored plaintext (admin needs to look it up)
  status            String    @default("Open")           // "Open" | "PickedUp" | "Released" | "Expired"
  assignedAt        DateTime  @default(now())
  expiresAt         DateTime                              // typically 7d after assigned
  pickedUpAt        DateTime?
  releasedAt        DateTime?
  releasedById      String?
  smsStatus         String?                               // "queued" | "sent" | "failed: …"
  notes             String?
  createdAt         DateTime  @default(now())

  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([lockboxId, status])
}

// One row per state-change event — every open/close/fault. Member-side
// webhook can subscribe to "your lockbox opened" by joining
// LockboxEvent.openedByUserId. Admins can audit "did box 14 sit open
// for 4 hours overnight?" by scanning this table.
model LockboxEvent {
  id              String    @id @default(cuid())
  lockboxId       String
  kind            String                            // "opened" | "closed" | "fault" | "manual_override"
  userId          String?                           // resolved member, when this open is tied to a code
  doorEntryId     String?                           // DoorAccessEntry.id, when keypad-driven
  reason          String?                           // free-form admin note
  durationSec     Int?                              // populated on closed events: how long the door was open
  expectedCloseBy DateTime?                         // snapshot of the deadline at open time, for overdue analysis
  recordedAt      DateTime  @default(now())

  lockbox Lockbox @relation(fields: [lockboxId], references: [id], onDelete: Cascade)

  @@index([lockboxId, recordedAt])
  @@index([kind, recordedAt])
  @@index([userId, recordedAt])
}

// iter-147 — Door-access keypad codes (Tier 9 #57).
// Each customer can have one ACTIVE 4-digit pickup code at a time.
// Rotation is scheduled (default 90 days) — admin sees a "Rotate now"
// button on stale codes. Every keypad entry attempt is logged so we
// have a chain-of-custody for after-hours access disputes.
//
// Code uniqueness: enforced ONLY among ACTIVE codes (one customer per
// code at a time). Old codes stay in the table marked retiredAt for
// audit but no longer constrain new code generation.
model DoorAccessCode {
  id           String    @id @default(cuid())
  userId       String
  code         String                            // 4-digit numeric, hashed at rest? — stored plain for now (ops practicality)
  issuedAt     DateTime  @default(now())
  rotateAt     DateTime                          // when the code becomes "stale" — admin sees Rotate Now CTA
  retiredAt    DateTime?                         // null = active, non-null = retired (kept for audit)
  retiredById  String?                           // admin who retired it
  notes        String?                           // optional admin note (e.g. "issued in person to Karim")
  createdById  String?                           // admin who created it

  user         User      @relation("DoorCodeUser", fields: [userId], references: [id], onDelete: Cascade)
  entries      DoorAccessEntry[]

  // Unique among ACTIVE codes only — enforced via a partial index in
  // SQLite (where retiredAt IS NULL). Prisma can't express partial
  // uniques today so we enforce in JS at write time + add a regular
  // index for fast lookup.
  @@index([code, retiredAt])
  @@index([userId, retiredAt])
  @@index([rotateAt])
}

// One row per attempt at the keypad. Result: "granted" | "denied".
// `code` stored even on denials so we can detect typos vs probes.
model DoorAccessEntry {
  id          String   @id @default(cuid())
  codeId      String?                            // null when an unknown code was entered
  userId      String?                            // resolved when the code matches
  enteredCode String                             // what was actually typed
  result      String                             // "granted" | "denied" | "denied_retired" | "denied_unknown"
  attemptedAt DateTime @default(now())

  code DoorAccessCode? @relation(fields: [codeId], references: [id], onDelete: SetNull)

  @@index([codeId, attemptedAt])
  @@index([result, attemptedAt])
}

// iter-145 — Equipment / scanner inventory (Tier 9 #56).
// Tracks every physical device the bureau uses (Jadens label printers,
// barcode scanners, cash drawers, cameras, payment terminals). Each
// row records serial + assignedTo + location + state. The
// EquipmentServiceLog table records every service event so admin can
// see the full lifecycle without spreadsheets.
// iter-228 — Suite ↔ printer pairing (Tier 17 #137).
//
// Admin claims a Bluetooth thermal printer (Equipment row with
// category="printer") for a specific suite #. When a new MailItem
// arrives or a member checks in, the iter-155 thermal print route
// auto-fires + targets the paired printer (admin sets the system's
// default printer to the paired one before printing). Per-suite
// auto flags let admin opt out of intake or pickup auto-print.
//
// One active pairing per suite — `@@unique([suiteNumber, releasedAt])`
// would be ideal but Prisma+SQLite needs `@@unique([suiteNumber])`
// with explicit release flow (set releasedAt + create new row).
model SuitePrinterPairing {
  id              String    @id @default(cuid())
  suiteNumber     String                                  // member's suite #
  equipmentId     String                                  // FK to Equipment (category=printer)
  printerLabel    String                                  // snapshot of equipment.name at pairing
  autoIntake      Boolean   @default(true)               // auto-print on new mail intake
  autoPickup      Boolean   @default(true)               // auto-print on pickup signed
  notes           String?
  claimedAt       DateTime  @default(now())
  claimedById     String                                  // admin who paired
  releasedAt      DateTime?                               // null = active
  releasedById    String?
  releasedReason  String?

  @@index([suiteNumber, releasedAt])
  @@index([equipmentId, releasedAt])
}

model Equipment {
  id              String   @id @default(cuid())
  name            String                          // "Jaden D300", "Honeywell 1900GHD", etc.
  category        String                          // "printer" | "scanner" | "computer" | "cash_drawer" | "camera" | "terminal" | "other"
  serial          String   @unique               // serial number (printed on the device)
  vendor          String?                         // "Jadens", "Honeywell", "Square"
  model           String?                         // model number
  purchasedAt     DateTime?
  purchasePriceCents Int?
  warrantyEndsAt  DateTime?
  location        String   @default("Bureau")     // "Bureau" | "Storage" | "Loaner" | "Off-site"
  assignedToUserId String?                        // admin staffer responsible
  status          String   @default("active")    // "active" | "needs_service" | "retired" | "lost"
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  serviceLog      EquipmentServiceLog[]

  @@index([category, status])
  @@index([location])
}

// One row per service / repair / replacement / inspection.
model EquipmentServiceLog {
  id            String   @id @default(cuid())
  equipmentId   String
  kind          String                          // "service" | "repair" | "calibration" | "battery" | "firmware" | "inspection" | "other"
  notes         String?
  costCents     Int?
  performedById String?                          // admin who logged the work
  performedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, performedAt])
}

// iter-143 — Suite cleaning / maintenance log.
// Records every cleaning, inspection, repair, lock-change, or other
// maintenance event per physical suite. Suites are referenced by their
// suite-number string (the same string on User.suiteNumber). When a
// suite is reassigned to a new customer, history is preserved under
// the same suite number.
model SuiteMaintenanceLog {
  id              String   @id @default(cuid())
  suiteNumber     String                        // matches User.suiteNumber
  kind            String                        // "cleaned" | "inspected" | "repaired" | "lock_changed" | "other"
  notes           String?
  performedById   String?                       // admin user id (nullable so legacy rows don't bind to one admin)
  performedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([suiteNumber, performedAt])
  @@index([kind, performedAt])
}

// iter-142 — Storage tier auto-graduation alerts.
// One row per (mailItemId × threshold) once the heads-up email has been
// sent. Threshold values: "14d", "30d", "60d". The cron sweeps daily;
// existing rows mean we don't re-send. Cleared automatically on pickup
// (cascade from MailItem.delete) — picked-up packages don't keep alert
// rows around.
model StorageThresholdAlert {
  id         String   @id @default(cuid())
  mailItemId String
  threshold  String   // "14d" | "30d" | "60d"
  feeAtAlertCents Int                     // snapshot of accumulated fee at alert time
  sentAt     DateTime @default(now())

  mailItem MailItem @relation(fields: [mailItemId], references: [id], onDelete: Cascade)

  @@unique([mailItemId, threshold])
  @@index([sentAt])
}

// iter-102 — ID-document expiry alerts.
// One row per (user × document × threshold) once the alert email has fired.
// Threshold values: "90d", "30d", "7d", "expired" — covers the staircase
// of urgency. The cron sweeps daily; existing rows mean we don't re-send.
model IdExpiryAlert {
  id        String   @id @default(cuid())
  userId    String
  document  String   // "primary" | "secondary"
  threshold String   // "90d" | "30d" | "7d" | "expired"
  expDate   String   // snapshot of the expiry date the alert was for
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, document, threshold, expDate])
  @@index([userId])
  @@index([sentAt])
}

model RecurringDelivery {
  id          String   @id @default(cuid())
  userId      String
  frequency   String   @default("weekly") // "weekly" | "biweekly" | "monthly"
  destination String
  tier        String   @default("standard") // "standard" | "express"
  notes       String?
  nextRunDate String   // "2025-07-01"
  lastRunDate String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// iter-29 notary booking + iter-160 calendar slots + iter-174 check-in workflow.
// Check-in fields snapshot the in-person verification: timestamp, ID
// type presented, witness name (if applicable), and a URL to a scan
// of the signed document for after-the-fact audit. Once
// `completedAt` is set the row freezes — admin can still view but no
// further state changes are allowed except admin override.
model NotaryBooking {
  id        String   @id @default(cuid())
  userId    String
  date      String
  time      String
  type      String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  notes     String?                                  // member-supplied at booking time

  // iter-174 — Witness check-in workflow.
  checkedInAt          DateTime?                     // when admin tapped "Check in" at the counter
  checkedInById        String?                       // admin who tapped check-in
  idPresented          String?                       // "DL" | "Passport" | "State ID" | "Military" | "Other"
  idPresentedNumber    String?                       // last 4 digits or full number — admin discretion
  signedDocumentUrl    String?                       // Vercel Blob URL of the post-notarization scan
  completedAt          DateTime?                     // when admin tapped "Complete"
  completedById        String?
  witnessName          String?                       // typed when a witness was present
  noShowAt             DateTime?                     // when admin or cron flagged the no-show
  noShowReason         String?
  adminNotes           String?                       // admin-only notes captured at check-in / completion

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, date])
  @@index([date, time])
}

model DeliveryOrder {

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  phone            String?
  passwordHash     String
  role             String   @default("USER") // "USER" | "ADMIN"
  plan             String?  // "Basic" | "Business" | "Premium"
  planTerm         String?  // "3" | "6" | "14"
  suiteNumber      String?  @unique
  status           String   @default("Active") // "Active" | "Expired"
  squareCustomerId String?  @unique // Linked Square customer ID
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mailItems           MailItem[]
  notaryBookings      NotaryBooking[]
  deliveryOrders      DeliveryOrder[]
  shopOrders          ShopOrder[]
  forwardingAddresses ForwardingAddress[]
  payments            Payment[]
}

model MailItem {
  id           String   @id @default(cuid())
  userId       String
  from         String
  type         String   // "Letter" | "Package"
  status       String   @default("Received") // "Received" | "Scanned" | "Awaiting Pickup" | "Forwarded" | "Picked Up" | "Held"
  scanned      Boolean  @default(false)
  scanImageUrl String?  // URL to scanned document image
  label        String?  // Custom label (e.g. "Tax Documents", "Legal", "Personal")
  date         String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotaryBooking {
  id        String   @id @default(cuid())
  userId    String
  date      String
  time      String
  type      String   // "Real Estate" | "Business Agreement" | "Legal Document"
  status    String   @default("Pending") // "Pending" | "Confirmed" | "Completed" | "Cancelled"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryOrder {
  id           String   @id @default(cuid())
  userId       String?
  customerName String
  phone        String
  email        String
  pickupAddr   String   @default("NOHO Mailbox, North Hollywood, CA")
  destination  String
  zip          String
  zone         String   // "NoHo" | "Extended"
  price        Float
  itemType     String   // "Letter" | "Package" | "Documents" | "Other"
  instructions String?
  courier      String?  // Courier/driver name
  status       String   @default("Pending") // "Pending" | "In Transit" | "Delivered"
  date         String
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ShopOrder {
  id            String   @id @default(cuid())
  userId        String
  items         String
  total         Float
  status        String   @default("Pending") // "Pending" | "Ready" | "Completed"
  squareOrderId String?  @unique // Linked Square order ID
  date          String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForwardingAddress {
  id      String @id @default(cuid())
  userId  String
  label   String
  address String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  service   String?
  message   String
  createdAt DateTime @default(now())
}

model Payment {
  id               String   @id @default(cuid())
  squarePaymentId  String   @unique
  userId           String?
  amount           Int      // Amount in cents
  currency         String   @default("USD")
  status           String   // "COMPLETED" | "PENDING" | "CANCELLED" | "FAILED"
  sourceType       String?  // "CARD" | "CASH" | "BANK_ACCOUNT" etc.
  receiptUrl       String?
  note             String?
  squareCreatedAt  String
  syncedAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CatalogItem {
  id              String   @id @default(cuid())
  squareCatalogId String   @unique
  name            String
  description     String?
  price           Int      // Price in cents
  currency        String   @default("USD")
  category        String?
  inStock         Boolean  @default(true)
  imageUrl        String?
  syncedAt        DateTime @default(now())
}

model SquareSyncLog {
  id          String   @id @default(cuid())
  syncType    String   // "customers" | "payments" | "catalog" | "all"
  status      String   // "running" | "completed" | "failed"
  itemsSynced Int      @default(0)
  errors      String?  // JSON string of errors
  startedAt   DateTime @default(now())
  completedAt DateTime?
}
